  )

(define (install-standard-sequence-extra-primitives! def)
  (def 'some
    (lambda (args state)
      (unless (>= (length args) 2)
        (runtime-raise 'arity "some: needs at least 2 arguments" args))
      (let ((pred  (car args))
            (lists (map (lambda (a) (runtime-list a "some")) (cdr args))))
        (let loop ((tails lists))
          (if (any null? tails)
              (host->runtime-value '())
              (let ((result (runtime-apply pred (map (lambda (t) (host->runtime-value (car t))) tails) state)))
                (if (runtime-truthy? result)
                    result
                    (loop (map cdr tails)))))))))
  (def 'every
    (lambda (args state)
      (unless (>= (length args) 2)
        (runtime-raise 'arity "every: needs at least 2 arguments" args))
      (let ((pred  (car args))
            (lists (map (lambda (a) (runtime-list a "every")) (cdr args))))
        (let loop ((tails lists) (last (host->runtime-value #t)))
          (if (any null? tails)
              last
              (let ((result (runtime-apply pred (map (lambda (t) (host->runtime-value (car t))) tails) state)))
                (if (runtime-truthy? result)
                    (loop (map cdr tails) result)
                    (host->runtime-value '()))))))))
  (def 'notany
    (lambda (args state)
      (unless (>= (length args) 2)
        (runtime-raise 'arity "notany: needs at least 2 arguments" args))
      (let ((pred  (car args))
            (lists (map (lambda (a) (runtime-list a "notany")) (cdr args))))
        (let loop ((tails lists))
          (if (any null? tails)
              (host->runtime-value #t)
              (let ((result (runtime-apply pred (map (lambda (t) (host->runtime-value (car t))) tails) state)))
                (if (runtime-truthy? result)
                    (host->runtime-value '())
                    (loop (map cdr tails)))))))))
  (def 'notevery
    (lambda (args state)
      (unless (>= (length args) 2)
        (runtime-raise 'arity "notevery: needs at least 2 arguments" args))
      (let ((pred  (car args))
            (lists (map (lambda (a) (runtime-list a "notevery")) (cdr args))))
        (let loop ((tails lists))
          (if (any null? tails)
              (host->runtime-value '())
              (let ((result (runtime-apply pred (map (lambda (t) (host->runtime-value (car t))) tails) state)))
                (if (runtime-truthy? result)
                    (host->runtime-value #t)
                    (loop (map cdr tails)))))))))
  (def 'map-into
    (lambda (args state)
      (unless (>= (length args) 3)
        (runtime-raise 'arity "map-into: needs target, fn, and at least one list" args))
      (let* ((target (runtime-value->host (car args)))
             (fn     (cadr args))
             (lists  (map (lambda (a) (runtime-list a "map-into")) (cddr args))))
        (unless (vector? target)
          (runtime-raise 'type-error "map-into: target must be a vector" target))
        (let loop ((i 0) (tails lists))
          (if (or (any null? tails) (>= i (vector-length target)))
              (host->runtime-value target)
              (begin
                (vector-set! target i
                             (runtime-value->host
                              (runtime-apply fn (map (lambda (t) (host->runtime-value (car t))) tails) state)))
                (loop (+ i 1) (map cdr tails))))))))
  (def 'convert
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "convert expects 2 arguments" args))
      (let* ((obj      (runtime-value->host (car args)))
             (class-arg (runtime-value->host (cadr args)))
             (cname    (cond ((rt-class? class-arg) (rt-class-name class-arg))
                             ((symbol? class-arg) class-arg)
                             (else (runtime-raise 'type-error "convert: second arg must be class" class-arg)))))
        (host->runtime-value
         (cond
          ((eq? cname '<integer>)
           (cond ((and (integer? obj) (exact? obj)) obj)
                 ((number? obj) (inexact->exact (truncate obj)))
                 ((char? obj) (char->integer obj))
                 (else (runtime-raise 'type-error "convert: cannot convert to <integer>" obj))))
          ((eq? cname '<float>)
           (cond ((number? obj) (exact->inexact obj))
                 (else (runtime-raise 'type-error "convert: cannot convert to <float>" obj))))
          ((eq? cname '<string>)
           (cond ((string? obj) obj)
                 ((symbol? obj) (symbol->string obj))
                 ((char? obj)   (string obj))
                 ((number? obj) (number->string obj))
                 ((list? obj)   (list->string obj))
                 (else (runtime-raise 'type-error "convert: cannot convert to <string>" obj))))
          ((eq? cname '<symbol>)
           (cond ((symbol? obj) obj)
                 ((string? obj) (string->symbol obj))
                 (else (runtime-raise 'type-error "convert: cannot convert to <symbol>" obj))))
          ((eq? cname '<list>)
           (cond ((list? obj)   obj)
                 ((string? obj) (string->list obj))
                 ((vector? obj) (vector->list obj))
                 (else (runtime-raise 'type-error "convert: cannot convert to <list>" obj))))
          ((eq? cname '<general-vector>)
           (cond ((vector? obj) obj)
                 ((list? obj)   (list->vector obj))
                 ((string? obj) (list->vector (string->list obj)))
                 (else (runtime-raise 'type-error "convert: cannot convert to <general-vector>" obj))))
          ((eq? cname '<character>)
           (cond ((char? obj) obj)
                 ((and (integer? obj) (exact? obj)) (integer->char obj))
                 (else (runtime-raise 'type-error "convert: cannot convert to <character>" obj))))
          (else
           (runtime-raise 'type-error "convert: unsupported target class" cname)))))))
  (def 'gensym
    (lambda (args state)
      (unless (or (= (length args) 0) (= (length args) 1))
        (runtime-raise 'arity "gensym expects 0 or 1 arguments" args))
      (let ((prefix (if (= (length args) 1)
                        (runtime-string (car args) "gensym")
                        "G")))
        (host->runtime-value (gensym prefix)))))
  (def 'create-string
    (lambda (args state)
      (unless (and (>= (length args) 1) (<= (length args) 2))
        (runtime-raise 'arity "create-string expects 1 or 2 arguments" args))
      (let ((n    (runtime-integer (car args) "create-string"))
            (init (if (= (length args) 2)
                      (let ((c (runtime-value->host (cadr args))))
                        (unless (char? c)
                          (runtime-raise 'type-error "create-string: second arg must be char" c))
                        c)
                      #\space)))
        (when (< n 0)
          (runtime-raise 'type-error "create-string: size must be non-negative" (car args)))
        (host->runtime-value (make-string n init)))))
  (def 'write-line
    (lambda (args state)
      (unless (and (>= (length args) 1) (<= (length args) 2))
        (runtime-raise 'arity "write-line expects 1 or 2 arguments" args))
      (let* ((s   (runtime-string (car args) "write-line"))
             (out (if (= (length args) 2)
                      (runtime-value->host (cadr args))
                      (current-output-port))))
        (unless (output-port? out)
          (runtime-raise 'type-error "write-line: second arg must be output stream" out))
        (display s out)
        (newline out)
        (host->runtime-value '()))))
  ;; ISLISP §15.8: append! — destructive append (alias for nconc)
  (def 'append!
    (lambda (args state)
      (let ((lists (map (lambda (x) (runtime-value->host x)) args)))
        (let loop ((ls lists))
          (cond
           ((null? ls) (host->runtime-value '()))
           ((null? (cdr ls)) (host->runtime-value (car ls)))
           ((null? (car ls)) (loop (cdr ls)))
           (else
            (let ((tail (loop (cdr ls))))
              (set-cdr! (let find-last ((x (car ls)))
                          (if (null? (cdr x)) x (find-last (cdr x))))
                        (runtime-value->host tail))
              (host->runtime-value (car ls)))))))))
  ;; ISLISP §15.1: set-car, set-cdr — mutate pair
  (def 'set-car
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "set-car expects 2 arguments" args))
      (let ((p   (runtime-value->host (car args)))
            (val (runtime-value->host (cadr args))))
        (unless (pair? p)
          (runtime-raise 'type-error "set-car: first argument must be a pair" (car args)))
        (set-car! p val)
        (host->runtime-value val))))
  (def 'set-cdr
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "set-cdr expects 2 arguments" args))
      (let ((p   (runtime-value->host (car args)))
            (val (runtime-value->host (cadr args))))
        (unless (pair? p)
          (runtime-raise 'type-error "set-cdr: first argument must be a pair" (car args)))
        (set-cdr! p val)
        (host->runtime-value val))))
  ;; ISLISP §15.3: elt — element of sequence (list, vector, string)
  (def 'elt
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "elt expects 2 arguments" args))
      (let ((seq (runtime-value->host (car args)))
            (z   (runtime-integer (cadr args) "elt")))
        (cond
         ((list? seq)
          (when (< z 0) (runtime-raise 'index-out-of-range "elt: index must be non-negative" (cadr args)))
          (let loop ((rest seq) (n z))
            (cond
             ((null? rest) (runtime-raise 'index-out-of-range "elt: index out of range" (cadr args)))
             ((= n 0) (host->runtime-value (car rest)))
             (else (loop (cdr rest) (- n 1))))))
         ((vector? seq)
          (when (or (< z 0) (>= z (vector-length seq)))
            (runtime-raise 'index-out-of-range "elt: vector index out of range" (cadr args)))
          (host->runtime-value (vector-ref seq z)))
         ((string? seq)
          (when (or (< z 0) (>= z (string-length seq)))
            (runtime-raise 'index-out-of-range "elt: string index out of range" (cadr args)))
          (host->runtime-value (string-ref seq z)))
         (else (runtime-raise 'type-error "elt: first argument must be a sequence" (car args)))))))
  ;; ISLISP §15.2: set-elt — sequence element setter
  (def 'set-elt
    (lambda (args state)
      (unless (= (length args) 3)
        (runtime-raise 'arity "set-elt expects 3 arguments" args))
      (let ((val (runtime-value->host (car args)))
            (seq (runtime-value->host (cadr args)))
            (z   (runtime-integer (caddr args) "set-elt")))
        (cond
         ((list? seq)
          (when (< z 0) (runtime-raise 'index-out-of-range "set-elt: index must be non-negative" (caddr args)))
          (let loop ((rest seq) (n z))
            (cond
             ((null? rest) (runtime-raise 'index-out-of-range "set-elt: index out of range" (caddr args)))
             ((= n 0) (set-car! rest val) (host->runtime-value val))
             (else (loop (cdr rest) (- n 1))))))
         ((vector? seq)
          (when (or (< z 0) (>= z (vector-length seq)))
            (runtime-raise 'index-out-of-range "set-elt: vector index out of range" (caddr args)))
          (vector-set! seq z val)
          (host->runtime-value val))
         ((string? seq)
          (when (or (< z 0) (>= z (string-length seq)))
            (runtime-raise 'index-out-of-range "set-elt: string index out of range" (caddr args)))
          (unless (char? val)
            (runtime-raise 'type-error "set-elt: value for string must be a character" (car args)))
          (string-set! seq z val)
          (host->runtime-value val))
         (else (runtime-raise 'type-error "set-elt: second argument must be a sequence" (cadr args)))))))
  ;; ISLISP §15.3: subseq — extract subsequence
  (def 'subseq
    (lambda (args state)
      (unless (= (length args) 3)
        (runtime-raise 'arity "subseq expects 3 arguments" args))
      (let ((seq (runtime-value->host (car args)))
            (z1  (runtime-integer (cadr args) "subseq"))
            (z2  (runtime-integer (caddr args) "subseq")))
        (cond
         ((list? seq)
          (when (or (< z1 0) (< z2 z1) (> z2 (length seq)))
            (runtime-raise 'index-out-of-range "subseq: invalid range" args))
          (let collect ((rest seq) (i 0) (acc '()))
            (if (or (null? rest) (>= i z2))
                (host->runtime-value (reverse acc))
                (collect (cdr rest) (+ i 1)
                         (if (>= i z1) (cons (car rest) acc) acc)))))
         ((vector? seq)
          (when (or (< z1 0) (< z2 z1) (> z2 (vector-length seq)))
            (runtime-raise 'index-out-of-range "subseq: invalid range" args))
          (let* ((new-v (make-vector (- z2 z1))))
            (let lp ((i z1))
              (unless (>= i z2)
                (vector-set! new-v (- i z1) (vector-ref seq i))
                (lp (+ i 1))))
            (host->runtime-value new-v)))
         ((string? seq)
          (when (or (< z1 0) (< z2 z1) (> z2 (string-length seq)))
            (runtime-raise 'index-out-of-range "subseq: invalid range" args))
          (host->runtime-value (substring seq z1 z2)))
         (else (runtime-raise 'type-error "subseq: first argument must be a sequence" (car args)))))))
  ;; ISLISP §11.2: integer-length — number of bits to represent n
  (def 'integer-length
    (lambda (args state)
      (unless (= (length args) 1)
        (runtime-raise 'arity "integer-length expects 1 argument" args))
      (let ((n (runtime-integer (car args) "integer-length")))
        (let ((m (if (< n 0) (- -1 n) n)))
          (if (= m 0)
              (host->runtime-value 0)
              (let loop ((bits 0) (x m))
                (if (= x 0)
                    (host->runtime-value bits)
                    (loop (+ bits 1) (quotient x 2)))))))))
  ;; general-vector-set! (setf place for general-vector-ref)
  (def 'general-vector-set!
    (lambda (args state)
      (unless (= (length args) 3)
        (runtime-raise 'arity "general-vector-set! expects 3 arguments" args))
      (let* ((v   (runtime-vector (car args) "general-vector-set!"))
             (i   (runtime-integer (cadr args) "general-vector-set!"))
             (val (runtime-value->host (caddr args))))
        (when (or (< i 0) (>= i (vector-length v)))
          (runtime-raise 'index-out-of-range "general-vector-set!: index out of range" (cadr args)))
        (vector-set! v i val)
        (host->runtime-value val))))
  (def 'eval
    (lambda (args state)
      (unless (= (length args) 1)
        (runtime-raise 'arity "eval expects 1 argument" args))
      (let* ((form  (runtime-value->host (car args)))
             (units (frontend-compile-forms (list form) (state-frontend-env state))))
        (runtime-load-units! state units)
        (state-last-value state))))
  )

(define (install-with-standard-primitives! def)
  ;; ---- ISLISP §18.2: with-standard-input/output/error-output helpers ----
  (def '%with-si-helper
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "%with-si-helper expects 2 arguments" args))
      (let ((port (runtime-value->host (car args)))
            (thunk (cadr args)))
        (unless (input-port? port)
          (runtime-raise 'type-error "with-standard-input: not an input stream" (car args)))
        (parameterize ((current-input-port port))
          (runtime-apply thunk '() state)))))
  (def '%with-so-helper
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "%with-so-helper expects 2 arguments" args))
      (let ((port (runtime-value->host (car args)))
            (thunk (cadr args)))
        (unless (output-port? port)
          (runtime-raise 'type-error "with-standard-output: not an output stream" (car args)))
        (parameterize ((current-output-port port))
          (runtime-apply thunk '() state)))))
  (def '%with-eo-helper
    (lambda (args state)
      (unless (= (length args) 2)
        (runtime-raise 'arity "%with-eo-helper expects 2 arguments" args))
      (let ((port (runtime-value->host (car args)))
            (thunk (cadr args)))
        (unless (output-port? port)
          (runtime-raise 'type-error "with-error-output: not an output stream" (car args)))
        (parameterize ((current-error-port port))
          (runtime-apply thunk '() state)))))
  )


