                   (members2 (if (dbms-auth-role-member-p auth grantee role)
                                 members
                                 (append members (list (list grantee role)))))
                   (saved (dbms-engine-save-auth-meta (dbms-auth-meta-with-memberships auth members2))))
              (if (dbms-error-p saved)
                  (dbms-make-result 'error saved)
                  (dbms-make-result-ok 'ok)))))))

(defun dbms-engine-revoke-role (_catalog stmt)
  (let* ((payload (third stmt))
         (role (dbms-assoc-get payload "role"))
         (grantee (dbms-assoc-get payload "grantee"))
         (auth (dbms-engine-load-auth-meta)))
    (if (not (dbms-auth-string-list-member-p role (dbms-auth-meta-roles auth)))
        (dbms-make-result-error 'dbms/role-not-found "role not found" role)
        (if (not (dbms-auth-string-list-member-p grantee (dbms-auth-meta-users auth)))
            (dbms-make-result-error 'dbms/user-not-found "user not found" grantee)
            (let ((saved (dbms-engine-save-auth-meta
                          (dbms-auth-meta-with-memberships auth
                                                           (dbms-auth-member-remove (dbms-auth-meta-memberships auth)
                                                                                    grantee
                                                                                    role)))))
              (if (dbms-error-p saved)
                  (dbms-make-result 'error saved)
                  (dbms-make-result-ok 'ok)))))))

(defun dbms-engine-grant-priv (_catalog stmt)
  (let* ((payload (third stmt))
         (privs (dbms-assoc-get payload "privileges"))
         (object (dbms-assoc-get payload "object"))
         (grantee (dbms-assoc-get payload "grantee"))
         (auth (dbms-engine-load-auth-meta))
         (grants (dbms-auth-meta-grants auth)))
    (if (not (or (dbms-auth-string-list-member-p grantee (dbms-auth-meta-users auth))
                 (dbms-auth-string-list-member-p grantee (dbms-auth-meta-roles auth))))
        (dbms-make-result-error 'dbms/user-not-found "grantee not found in users/roles" grantee)
        (progn
          (dolist (p privs)
            (setq grants (dbms-auth-grant-add grants grantee object p)))
          (let ((saved (dbms-engine-save-auth-meta (dbms-auth-meta-with-grants auth grants))))
            (if (dbms-error-p saved)
                (dbms-make-result 'error saved)
                (dbms-make-result-ok 'ok)))))))

(defun dbms-engine-revoke-priv (_catalog stmt)
  (let* ((payload (third stmt))
         (privs (dbms-assoc-get payload "privileges"))
         (object (dbms-assoc-get payload "object"))
         (grantee (dbms-assoc-get payload "grantee"))
         (auth (dbms-engine-load-auth-meta))
         (grants (dbms-auth-meta-grants auth)))
    (dolist (p privs)
      (setq grants (dbms-auth-grant-remove grants grantee object p)))
    (let ((saved (dbms-engine-save-auth-meta (dbms-auth-meta-with-grants auth grants))))
      (if (dbms-error-p saved)
          (dbms-make-result 'error saved)
          (dbms-make-result-ok 'ok)))))

(defun dbms-engine-set-role (_catalog stmt)
  (let* ((role (dbms-assoc-get (third stmt) "role"))
         (auth (dbms-engine-load-auth-meta)))
    (if (not (dbms-auth-string-list-member-p role (dbms-auth-meta-roles auth)))
        (dbms-make-result-error 'dbms/role-not-found "role not found" role)
        (if (or (dbms-auth-role-member-p auth *dbms-session-user* role)
                (string= *dbms-session-user* "admin"))
            (progn
              (setq *dbms-session-active-role* role)
              (dbms-make-result-ok 'ok))
            (dbms-make-result-error 'dbms/permission-denied "role is not granted to current user" role)))))

(defun dbms-engine-begin (_catalog _stmt)
  (if (dbms-tx-active-p)
      (dbms-make-result-error 'dbms/tx-already-active "transaction is already active" 'BEGIN)
      (let ((tx-id *dbms-next-tx-id*)
            (catalog (dbms-catalog-load))
            (auth (dbms-auth-ensure-bootstrap (dbms-storage-load-auth-meta)))
            (states '()))
        (setq states (dbms-load-table-states (dbms-catalog-table-names catalog)))
        (setq *dbms-tx-snapshot-catalog* catalog)
        (setq *dbms-tx-snapshot-auth* auth)
        (if (dbms-error-p states)
            (setq *dbms-tx-snapshot-states* '())
            (setq *dbms-tx-snapshot-states* states))
        (setq *dbms-tx-staged-catalog* catalog)
        (setq *dbms-tx-staged-table-states* (if (dbms-error-p states) '() states))
        (setq *dbms-tx-staged-auth* auth)
        (setq *dbms-next-tx-id* (+ *dbms-next-tx-id* 1))
        (setq *dbms-tx-isolation-level* *dbms-session-isolation-level*)
        (setq *dbms-tx-state* (dbms-make-tx-state 'active '() '() tx-id))
        (dbms-make-result-ok 'ok))))

(defun dbms-engine-commit (_catalog _stmt)
  (if (eq (dbms-tx-state-status *dbms-tx-state*) 'active)
      (let ((tx-id (dbms-tx-state-tx-id *dbms-tx-state*))
            (writes (dbms-tx-state-write-set *dbms-tx-state*))
            (failed '())
            (result '()))
        ;; WAL append/flush must complete before any data file writes.
        (let ((wal-begin (dbms-storage-wal-append-record tx-id 'begin 'tx-begin '())))
          (if (dbms-error-p wal-begin)
              (setq failed wal-begin)
              nil))
        (if (and (null failed) (dbms-catalog-p *dbms-tx-staged-catalog*))
            (let ((wal-catalog (dbms-storage-wal-append-record tx-id
                                                               'data
                                                               'catalog-replace
                                                               (list *dbms-tx-staged-catalog*))))
              (if (dbms-error-p wal-catalog)
                  (setq failed wal-catalog)
                  nil))
            nil)
        (if (and (null failed) (dbms-auth-meta-p *dbms-tx-staged-auth*))
            (let ((wal-auth (dbms-storage-wal-append-record tx-id
                                                            'data
                                                            'auth-replace
                                                            (list *dbms-tx-staged-auth*))))
              (if (dbms-error-p wal-auth)
                  (setq failed wal-auth)
                  nil))
            nil)
        (dolist (name writes)
          (if (dbms-error-p failed)
              nil
              (let ((entry (dbms-find-staged-table-state-pair name *dbms-tx-staged-table-states*)))
                (if (null entry)
                    nil
                    (let* ((state (second entry))
                           (wal-table (dbms-storage-wal-append-record tx-id
                                                                      'data
                                                                      'table-replace
                                                                      (list name state))))
                      (if (dbms-error-p wal-table)
                          (setq failed wal-table)
                          nil))))))
        (if (null failed)
            (let ((wal-commit (dbms-storage-wal-append-record tx-id 'commit 'tx-commit '())))
              (if (dbms-error-p wal-commit)
                  (setq failed wal-commit)
                  nil))
            nil)
        (if (null failed)
            (dbms-test-commit-failpoint tx-id)
            nil)

        ;; Data-file commit phase (after WAL commit marker has been persisted).
        (if (and (null failed) (dbms-catalog-p *dbms-tx-staged-catalog*))
            (let ((saved-catalog (dbms-catalog-save *dbms-tx-staged-catalog*)))
              (if (dbms-error-p saved-catalog)
                  (setq failed saved-catalog)
                  nil))
            nil)
        (if (and (null failed) (dbms-auth-meta-p *dbms-tx-staged-auth*))
            (let ((saved-auth (dbms-storage-save-auth-meta *dbms-tx-staged-auth*)))
              (if (dbms-error-p saved-auth)
                  (setq failed saved-auth)
                  nil))
            nil)
        (dolist (name writes)
          (if (dbms-error-p failed)
              nil
              (let ((entry (dbms-find-staged-table-state-pair name *dbms-tx-staged-table-states*)))
                (if (null entry)
                    nil
                    (let* ((state (second entry))
                           (saved (dbms-storage-save-table-rows name (third state))))
                      (if (dbms-error-p saved)
                          (setq failed saved)
                          nil))))))
        ;; Rebuild index files for tables touched in this transaction.
        (dolist (name writes)
          (if (dbms-error-p failed)
              nil
              (let ((table-def (dbms-catalog-find-table *dbms-tx-staged-catalog* name)))
                (if (null table-def)
                    nil
                    (let* ((entry (dbms-find-staged-table-state-pair name *dbms-tx-staged-table-states*))
                           (state (if (null entry)
                                      (dbms-storage-load-table-rows name)
                                      (second entry))))
                      (if (dbms-error-p state)
                          (setq failed state)
                          (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def name table-def (third state))))
                            (if (dbms-error-p rebuild)
                                (setq failed rebuild)
                                nil))))))))
        (setq result
              (if (dbms-error-p failed)
            (progn
              (dbms-engine-audit-tx-abort tx-id 'commit-failed failed)
              (dbms-metrics-inc! "tx-aborted")
              (setq *dbms-tx-state* (dbms-make-tx-state 'aborted
                                                        (dbms-tx-state-read-set *dbms-tx-state*)
                                                        (dbms-tx-state-write-set *dbms-tx-state*)
                                                        tx-id))
              (dbms-lock-release-tx tx-id)
              (dbms-make-result 'error failed))
            (progn
              (dbms-metrics-inc! "tx-committed")
              (setq *dbms-tx-state* (dbms-make-tx-state 'committed
                                                        (dbms-tx-state-read-set *dbms-tx-state*)
                                                        (dbms-tx-state-write-set *dbms-tx-state*)
                                                        tx-id))
              (dbms-lock-release-tx tx-id)
              (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
              (setq *dbms-tx-state* (dbms-tx-state-idle))
              (dbms-make-result-ok 'ok))))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-snapshot-auth* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (setq *dbms-tx-staged-auth* '())
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        (dbms-engine-clear-read-cache!)
        result)
      (progn
        (setq *dbms-tx-state* (dbms-tx-state-idle))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-snapshot-auth* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (setq *dbms-tx-staged-auth* '())
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        (dbms-make-result-error 'dbms/tx-not-active "no active transaction" 'COMMIT))))

(defun dbms-engine-rollback (_catalog _stmt)
  (if (eq (dbms-tx-state-status *dbms-tx-state*) 'active)
      (let ((tx-id (dbms-tx-state-tx-id *dbms-tx-state*))
            (failed '()))
        ;; Restore catalog first, then table states captured at BEGIN.
        (if (dbms-catalog-p *dbms-tx-snapshot-catalog*)
            (let ((saved-catalog (dbms-catalog-save *dbms-tx-snapshot-catalog*)))
              (if (dbms-error-p saved-catalog)
                  (setq failed saved-catalog)
                  nil))
            nil)
        (if (and (null failed) (dbms-auth-meta-p *dbms-tx-snapshot-auth*))
            (let ((saved-auth (dbms-storage-save-auth-meta *dbms-tx-snapshot-auth*)))
              (if (dbms-error-p saved-auth)
                  (setq failed saved-auth)
                  nil))
            nil)
        (if (dbms-error-p failed)
            nil
            (dolist (entry *dbms-tx-snapshot-states*)
              (if (dbms-error-p failed)
                  nil
                  (let ((name (first entry))
                        (state (second entry)))
                    (if (or (not (stringp name)) (not (dbms-table-state-p state)))
                        (setq failed (dbms-make-error 'dbms/invalid-representation "invalid tx snapshot state" entry))
                        (let ((saved (dbms-storage-save-table-rows name (third state))))
                          (if (dbms-error-p saved)
                              (setq failed saved)
                              nil)))))))
        (setq *dbms-tx-state* (dbms-make-tx-state 'aborted
                                                  (dbms-tx-state-read-set *dbms-tx-state*)
                                                  (dbms-tx-state-write-set *dbms-tx-state*)
                                                  tx-id))
        (dbms-metrics-inc! "tx-aborted")
        (dbms-engine-audit-tx-abort tx-id 'rollback (if (dbms-error-p failed) failed 'ok))
        (dbms-lock-release-tx tx-id)
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        (setq *dbms-tx-state* (dbms-tx-state-idle))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-snapshot-auth* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (setq *dbms-tx-staged-auth* '())
        (dbms-engine-clear-read-cache!)
        (if (dbms-error-p failed)
            (dbms-make-result 'error failed)
            (dbms-make-result-ok 'ok)))
      (dbms-make-result-error 'dbms/tx-not-active "no active transaction" 'ROLLBACK)))

(defun dbms-catalog-table-names (catalog)
  (let ((pairs (dbms-catalog-tables catalog))
        (out '()))
    (dolist (p pairs)
      (setq out (append out (list (first p)))))
    out))

(defun dbms-load-table-states (table-names)
  (let ((rest table-names)
        (out '())
        (failed '()))
    (while (and (null failed) (not (null rest)))
      (let* ((name (car rest))
             (state (dbms-storage-load-table-rows name)))
        (if (dbms-error-p state)
            (setq failed state)
            (setq out (append out (list (list name state))))))
      (setq rest (cdr rest)))
    (if (dbms-error-p failed)
        failed
        out)))

(defun dbms-dump-payload-p (v)
  (and (listp v)
       (>= (length v) 4)
       (eq (first v) 'dbms-dump)
       (numberp (second v))
       (dbms-catalog-p (third v))
       (listp (fourth v))))

(defun dbms-admin-build-dump-payload ()
  (let* ((catalog (dbms-catalog-load))
         (table-names (dbms-catalog-table-names catalog))
         (states (dbms-load-table-states table-names)))
    (if (dbms-error-p states)
        states
        (list 'dbms-dump 1 catalog states))))

(defun dbms-admin-dump (dump-path)
  (if (or (null dump-path) (not (stringp dump-path)) (string= dump-path ""))
      (dbms-make-result-error 'dbms/invalid-representation "dump-path must be non-empty string" dump-path)
      (let ((payload (dbms-admin-build-dump-payload)))
        (if (dbms-error-p payload)
            (dbms-make-result 'error payload)
            (let ((saved (dbms-storage-atomic-replace dump-path payload)))
              (if (dbms-error-p saved)
                  (dbms-make-result 'error saved)
                  (dbms-make-result-ok dump-path)))))))

(defun dbms-admin-restore (dump-path)
  (if (or (null dump-path) (not (stringp dump-path)) (string= dump-path ""))
      (dbms-make-result-error 'dbms/invalid-representation "dump-path must be non-empty string" dump-path)
      (let ((raw (dbms-storage-read-sexpr-file dump-path)))
        (if (not (dbms-dump-payload-p raw))
            (dbms-make-result-error 'dbms/invalid-representation "invalid dump payload" dump-path)
            (let* ((catalog (third raw))
                   (states (fourth raw))
                   (saved-catalog (dbms-catalog-save catalog))
                   (failed '()))
              (if (dbms-error-p saved-catalog)
                  (dbms-make-result 'error saved-catalog)
                  (progn
                    (dolist (entry states)
                      (if (dbms-error-p failed)
                          nil
                          (let ((name (first entry))
                                (state (second entry)))
                            (if (or (not (stringp name))
                                    (not (dbms-table-state-p state)))
                                (setq failed (dbms-make-error 'dbms/invalid-representation "invalid table-state entry in dump" entry))
                                (let ((saved (dbms-storage-save-table-rows name (third state))))
                                  (if (dbms-error-p saved)
                                      (setq failed saved)
                                      (let ((table-def (dbms-catalog-find-table catalog name)))
                                        (if (null table-def)
                                            nil
                                            (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def name table-def (third state))))
                                              (if (dbms-error-p rebuild)
                                                  (setq failed rebuild)
                                                  nil))))))))))
                    (if (dbms-error-p failed)
                        (dbms-make-result 'error failed)
                        (progn
                          (dbms-engine-clear-read-cache!)
                          (dbms-make-result-ok dump-path))))))))))

(defun dbms-admin-metrics-reset ()
  (dbms-engine-reset-metrics!)
  (dbms-engine-clear-read-cache!)
  (dbms-make-result-ok 'ok))

(defun dbms-admin-checkpoint-info ()
  (dbms-make-result-ok (dbms-storage-load-checkpoint-meta)))

(defun dbms-admin-checkpoint-create ()
  (if (dbms-tx-active-p)
      (dbms-make-result-error 'dbms/tx-already-active "cannot checkpoint while transaction is active" *dbms-tx-state*)
      (let ((checkpoint (dbms-storage-create-checkpoint)))
        (if (dbms-error-p checkpoint)
            (dbms-make-result 'error checkpoint)
            (dbms-make-result-ok checkpoint)))))

(defun dbms-admin-metrics ()
  (let* ((started-at (dbms-metrics-get "started-at"))
         (committed (dbms-metrics-get "tx-committed"))
         (aborted (dbms-metrics-get "tx-aborted"))
         (lock-waits (dbms-metrics-get "lock-wait-events"))
         (lock-conflicts (dbms-metrics-get "lock-conflicts"))
         (deadlocks (dbms-metrics-get "deadlock-detected"))
         (cache-hit (dbms-metrics-get "cache-hit"))
         (cache-miss (dbms-metrics-get "cache-miss"))
         (recovery-lag (dbms-metrics-get "recovery-lag-records"))
         (last-recovery-at (dbms-metrics-get "last-recovery-at"))
         (elapsed (- (get-universal-time) started-at))
         (tx-per-sec 0)
         (total-cache 0)
         (cache-hit-ratio 0))
    (if (<= elapsed 0)
        (setq elapsed 1)
        nil)
    (setq tx-per-sec (/ committed elapsed))
    (setq total-cache (+ cache-hit cache-miss))
    (if (> total-cache 0)
        (setq cache-hit-ratio (/ cache-hit total-cache))
        (setq cache-hit-ratio 0))
    (dbms-make-result-rows
     '("metric" "value")
     (list (list "tx-per-sec" tx-per-sec)
           (list "tx-committed" committed)
           (list "tx-aborted" aborted)
           (list "lock-wait-events" lock-waits)
           (list "lock-conflicts" lock-conflicts)
           (list "deadlock-detected" deadlocks)
           (list "cache-hit" cache-hit)
           (list "cache-miss" cache-miss)
           (list "cache-hit-ratio" cache-hit-ratio)
           (list "recovery-lag-records" recovery-lag)
           (list "last-recovery-at" last-recovery-at)
           (list "started-at" started-at)
           (list "uptime-sec" elapsed)))))

(defun dbms-admin-backup-create ()
  (if (dbms-tx-active-p)
      (dbms-make-result-error 'dbms/tx-already-active "cannot create backup while transaction is active" *dbms-tx-state*)
      (let ((payload (dbms-admin-build-dump-payload)))
        (if (dbms-error-p payload)
            (dbms-make-result 'error payload)
            (let ((entry (dbms-storage-create-backup-generation payload)))
              (if (dbms-error-p entry)
                  (dbms-make-result 'error entry)
                  (dbms-make-result-ok entry)))))))

(defun dbms-admin-backup-list ()
  (dbms-make-result-ok (dbms-storage-list-backup-generations)))

(defun dbms-admin-restore-pitr (generation-id target-lsn)
  (if (or (null generation-id) (not (stringp generation-id)) (string= generation-id ""))
      (dbms-make-result-error 'dbms/invalid-representation "generation-id must be non-empty string" generation-id)
      (if (or (not (numberp target-lsn)) (< target-lsn 0))
          (dbms-make-result-error 'dbms/invalid-representation "target-lsn must be non-negative number" target-lsn)
          (if (dbms-tx-active-p)
              (dbms-make-result-error 'dbms/tx-already-active "cannot restore pitr while transaction is active" *dbms-tx-state*)
              (let ((entry (dbms-storage-find-backup-generation generation-id)))
                (if (null entry)
                    (dbms-make-result-error 'dbms/invalid-representation "backup generation not found" generation-id)
                    (let ((base-lsn (dbms-backup-generation-base-lsn entry))
                          (max-lsn (dbms-backup-generation-max-lsn entry)))
                      (if (or (< target-lsn base-lsn) (> target-lsn max-lsn))
                          (dbms-make-result-error 'dbms/invalid-representation "target-lsn out of backup range" (list generation-id target-lsn base-lsn max-lsn))
                          (let* ((dump-path (dbms-backup-generation-dump-path entry))
                                 (restored (dbms-admin-restore dump-path)))
                            (if (and (dbms-result-p restored) (eq (second restored) 'error))
                                restored
                                (let ((records (dbms-storage-load-backup-wal-records generation-id)))
                                  (if (dbms-error-p records)
                                      (dbms-make-result 'error records)
                                      (let ((report (dbms-storage-replay-wal-records-up-to-lsn records target-lsn)))
                                        (if (dbms-error-p report)
                                            (dbms-make-result 'error report)
                                            (let ((trimmed '())
                                                  (rest records)
                                                  (saved-wal '()))
                                              (while (not (null rest))
                                                (if (<= (dbms-wal-record-lsn (car rest)) target-lsn)
                                                    (setq trimmed (append trimmed (list (car rest))))
                                                    nil)
                                                (setq rest (cdr rest)))
                                              (setq saved-wal (dbms-storage-save-wal-records trimmed))
                                              (if (dbms-error-p saved-wal)
                                                  (dbms-make-result 'error saved-wal)
                                                  (progn
                                                    (dbms-engine-reset-tx-state)
                                                    (dbms-engine-clear-read-cache!)
                                                    (setq *dbms-next-tx-id* (+ (dbms-storage-wal-max-txid) 1))
                                                    (dbms-make-result-ok
                                                     (list generation-id
                                                           target-lsn
                                                           report)))))))))))))))))))

;; Wiki admin compatibility wrappers:
;; ("ok" <path>) | ("error" <message>)
(defun dbms-wiki-backup (dump-path)
  (let ((r (dbms-admin-dump dump-path)))
    (if (and (dbms-result-p r) (eq (second r) 'ok))
        (list "ok" (third r))
        (if (and (dbms-result-p r) (eq (second r) 'error) (dbms-error-p (third r)))
            (list "error" (third (third r)))
            (list "error" "backup failed")))))

(defun dbms-wiki-restore (dump-path)
  (let ((r (dbms-admin-restore dump-path)))
    (if (and (dbms-result-p r) (eq (second r) 'ok))
        (list "ok" (third r))
        (if (and (dbms-result-p r) (eq (second r) 'error) (dbms-error-p (third r)))
            (list "error" (third (third r)))
            (list "error" "restore failed")))))

(defun dbms-engine-dispatch (catalog stmt)
  (let ((kind (second stmt))
        (mode '())
        (target "")
        (lock-res '())
        (authz '())
        (result '()))
    (if (dbms-tx-active-p)
        (progn
          (setq mode (dbms-stmt-lock-mode kind))
          (setq target (dbms-stmt-lock-target stmt))
          (if (and (not (null mode))
                   (not (string= target "")))
              (progn
                (setq lock-res (dbms-lock-acquire (dbms-tx-state-tx-id *dbms-tx-state*) target mode))
                (if (dbms-error-p lock-res)
                    (progn
                      (if (or (eq (dbms-error-code lock-res) 'dbms/deadlock-detected)
                              (eq *dbms-tx-isolation-level* 'SERIALIZABLE))
                          (dbms-abort-active-tx-on-conflict!)
                          nil)
                      (setq result (dbms-make-result 'error lock-res)))
                    nil))
              nil))
        nil)
    (if (and (dbms-result-p result) (eq (second result) 'error))
        result
        (progn
          (setq authz (dbms-engine-authorize-statement stmt))
          (if (dbms-error-p authz)
              (setq result (dbms-make-result 'error authz))
              nil)
          (if (and (dbms-result-p result) (eq (second result) 'error))
              result
              (progn
                (setq result
                      (cond
                       ((eq kind 'begin) (dbms-engine-begin catalog stmt))
                       ((eq kind 'commit) (dbms-engine-commit catalog stmt))
                       ((eq kind 'rollback) (dbms-engine-rollback catalog stmt))
                       ((eq kind 'set-role) (dbms-engine-set-role catalog stmt))
                       ((eq kind 'create-user) (dbms-engine-create-user catalog stmt))
                       ((eq kind 'create-role) (dbms-engine-create-role catalog stmt))
                       ((eq kind 'grant-role) (dbms-engine-grant-role catalog stmt))
                       ((eq kind 'revoke-role) (dbms-engine-revoke-role catalog stmt))
                       ((eq kind 'grant-priv) (dbms-engine-grant-priv catalog stmt))
                       ((eq kind 'revoke-priv) (dbms-engine-revoke-priv catalog stmt))
                       ((eq kind 'create-table) (dbms-engine-create-table catalog stmt))
                       ((eq kind 'create-table-wiki) (dbms-engine-create-table-wiki catalog stmt))
                       ((eq kind 'create-index) (dbms-engine-create-index catalog stmt))
                       ((eq kind 'analyze) (dbms-engine-analyze catalog stmt))
                       ((eq kind 'vacuum) (dbms-engine-vacuum catalog stmt))
                       ((eq kind 'explain) (dbms-engine-explain catalog stmt))
                       ((eq kind 'alter-table) (dbms-engine-alter-table catalog stmt))
                       ((eq kind 'insert) (dbms-engine-insert catalog stmt))
                       ((eq kind 'select) (dbms-engine-select catalog stmt))
                       ((eq kind 'update) (dbms-engine-update catalog stmt))
                       ((eq kind 'delete) (dbms-engine-delete catalog stmt))
                       (t (dbms-make-result-error 'dbms/not-implemented "statement not implemented" kind))))
                (if (and (dbms-result-p result)
                         (not (eq (second result) 'error)))
                    (progn
                      (dbms-tx-record-statement! stmt)
                      (dbms-engine-audit-statement-success stmt))
                    nil)
                ;; READ COMMITTED: release shared read locks at statement boundary.
                (if (and (dbms-tx-active-p)
                         (or (eq kind 'select)
                             (eq kind 'explain))
                         (eq *dbms-tx-isolation-level* 'READ-COMMITTED)
                         (not (string= target "")))
                    (dbms-lock-release-shared-on-table (dbms-tx-state-tx-id *dbms-tx-state*) target)
                    nil)
                result))))))

(defun dbms-exec-sql (catalog sql-text)
  (let ((ast (dbms-parse-sql sql-text))
        (effective-catalog (dbms-engine-current-catalog)))
    (if (dbms-error-p ast)
        (dbms-make-result 'error ast)
        (let ((stmts (dbms-ast-statements ast)))
          (if (or (null stmts) (not (= (length stmts) 1)))
              (dbms-make-result-error 'dbms/parse-error "single statement required" sql-text)
              (dbms-engine-dispatch effective-catalog (first stmts)))))))
