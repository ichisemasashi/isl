;; dbms/app/engine.lsp
;; SQL実行エンジン（MVP Core）。

(load "./examples/dbms/app/repr.lsp")
(load "./examples/dbms/app/profile.lsp")
(load "./examples/dbms/app/catalog.lsp")
(load "./examples/dbms/app/storage.lsp")
(load "./examples/dbms/app/sql_parser.lsp")

(defglobal *dbms-tx-state* (dbms-tx-state-idle))
(defglobal *dbms-next-tx-id* 1)
(defglobal *dbms-tx-snapshot-catalog* '())
(defglobal *dbms-tx-snapshot-states* '())
(defglobal *dbms-tx-staged-catalog* '())
(defglobal *dbms-tx-staged-table-states* '())
;; lock entry: (<table-name> <mode:S|X> <holders:(txid ...)>)
(defglobal *dbms-lock-table* '())
;; wait-for graph entry: (<txid> <waiting-on-txids...>)
(defglobal *dbms-wait-for-graph* '())
;; isolation level:
;;   READ-COMMITTED: SELECT S lock is statement-boundary
;;   SERIALIZABLE  : SELECT S lock is tx-boundary
(defglobal *dbms-session-isolation-level* 'READ-COMMITTED)
(defglobal *dbms-tx-isolation-level* 'READ-COMMITTED)

(defun dbms-engine-init ()
  (let ((recovered (dbms-storage-recover-from-wal))
        (next-tx-id (+ (dbms-storage-wal-max-txid) 1)))
    ;; Startup path: ensure tx runtime state is reset and txid monotonicity survives restart.
    (dbms-engine-reset-tx-state)
    (if (> next-tx-id 1)
        (setq *dbms-next-tx-id* next-tx-id)
        nil)
    (if (dbms-error-p recovered)
        (format t "[dbms-recovery-warning] ~A~%" recovered)
        nil)
    (dbms-catalog-load)))

(defun dbms-current-tx-state ()
  *dbms-tx-state*)

(defun dbms-engine-reset-tx-state ()
  (setq *dbms-tx-state* (dbms-tx-state-idle))
  (setq *dbms-next-tx-id* 1)
  (setq *dbms-tx-snapshot-catalog* '())
  (setq *dbms-tx-snapshot-states* '())
  (setq *dbms-tx-staged-catalog* '())
  (setq *dbms-tx-staged-table-states* '())
  (setq *dbms-lock-table* '())
  (setq *dbms-wait-for-graph* '())
  (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
  *dbms-tx-state*)

(defun dbms-tx-active-p ()
  (eq (dbms-tx-state-status *dbms-tx-state*) 'active))

(defun dbms-lock-table-reset! ()
  (setq *dbms-lock-table* '())
  (setq *dbms-wait-for-graph* '())
  *dbms-lock-table*)

(defun dbms-lock-table-snapshot ()
  *dbms-lock-table*)

(defun dbms-wait-for-graph-snapshot ()
  *dbms-wait-for-graph*)

(defun dbms-isolation-level-valid-p (level)
  (or (eq level 'READ-COMMITTED)
      (eq level 'SERIALIZABLE)))

(defun dbms-set-session-isolation-level! (level)
  (if (dbms-isolation-level-valid-p level)
      (progn
        (setq *dbms-session-isolation-level* level)
        level)
      (dbms-make-error 'dbms/invalid-representation "isolation level must be READ-COMMITTED or SERIALIZABLE" level)))

(defun dbms-current-session-isolation-level ()
  *dbms-session-isolation-level*)

(defun dbms-current-tx-isolation-level ()
  *dbms-tx-isolation-level*)

(defun dbms-abort-active-tx-on-conflict! ()
  (if (dbms-tx-active-p)
      (let ((tx-id (dbms-tx-state-tx-id *dbms-tx-state*)))
        (dbms-lock-release-tx tx-id)
        (dbms-wfg-clear-tx tx-id)
        (setq *dbms-tx-state* (dbms-make-tx-state 'aborted
                                                  (dbms-tx-state-read-set *dbms-tx-state*)
                                                  (dbms-tx-state-write-set *dbms-tx-state*)
                                                  tx-id))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        t)
      nil))

(defun dbms-number-in-list-p (n xs)
  (if (null xs)
      nil
      (if (= n (car xs))
          t
          (dbms-number-in-list-p n (cdr xs)))))

(defun dbms-lock-find-entry (table-name entries)
  (if (null entries)
      '()
      (let ((e (car entries)))
        (if (string= (first e) table-name)
            e
            (dbms-lock-find-entry table-name (cdr entries))))))

(defun dbms-lock-put-entry (table-name mode holders entries)
  (if (null entries)
      (list (list table-name mode holders))
      (let ((e (car entries)))
        (if (string= (first e) table-name)
            (cons (list table-name mode holders) (cdr entries))
            (cons e (dbms-lock-put-entry table-name mode holders (cdr entries)))))))

(defun dbms-lock-remove-entry (table-name entries)
  (if (null entries)
      '()
      (let ((e (car entries)))
        (if (string= (first e) table-name)
            (dbms-lock-remove-entry table-name (cdr entries))
            (cons e (dbms-lock-remove-entry table-name (cdr entries)))))))

(defun dbms-lock-remove-txid-from-holders (txid holders)
  (if (null holders)
      '()
      (if (= txid (car holders))
          (dbms-lock-remove-txid-from-holders txid (cdr holders))
          (cons (car holders) (dbms-lock-remove-txid-from-holders txid (cdr holders))))))

(defun dbms-wfg-find-entry (txid graph)
  (if (null graph)
      '()
      (let ((e (car graph)))
        (if (= txid (first e))
            e
            (dbms-wfg-find-entry txid (cdr graph))))))

(defun dbms-wfg-put-entry (txid waits graph)
  (if (null graph)
      (list (list txid waits))
      (let ((e (car graph)))
        (if (= txid (first e))
            (cons (list txid waits) (cdr graph))
            (cons e (dbms-wfg-put-entry txid waits (cdr graph)))))))

(defun dbms-wfg-out-neighbors (txid)
  (let ((e (dbms-wfg-find-entry txid *dbms-wait-for-graph*)))
    (if (null e) '() (second e))))

(defun dbms-wfg-clear-tx (txid)
  (let ((rest *dbms-wait-for-graph*)
        (out '()))
    (while (not (null rest))
      (let* ((e (car rest))
             (src (first e))
             (waits (second e)))
        (if (= src txid)
            nil
            (let ((new-waits (dbms-lock-remove-txid-from-holders txid waits)))
              (if (null new-waits)
                  nil
                  (setq out (append out (list (list src new-waits))))))))
      (setq rest (cdr rest)))
    (setq *dbms-wait-for-graph* out)
    t))

(defun dbms-wfg-add-edges (requester holders)
  (let ((clean (dbms-lock-remove-txid-from-holders requester holders))
        (existing (dbms-wfg-out-neighbors requester)))
    (dolist (h clean)
      (if (dbms-number-in-list-p h existing)
          nil
          (setq existing (append existing (list h)))))
    (if (null existing)
        nil
        (setq *dbms-wait-for-graph*
              (dbms-wfg-put-entry requester existing *dbms-wait-for-graph*)))
    existing))

(defun dbms-wfg-path-exists-p (from to visited)
  (if (= from to)
      t
      (if (dbms-number-in-list-p from visited)
          nil
          (let ((nexts (dbms-wfg-out-neighbors from))
                (ok nil)
                (vis2 (append visited (list from))))
            (while (and (not ok) (not (null nexts)))
              (if (dbms-wfg-path-exists-p (car nexts) to vis2)
                  (setq ok t)
                  nil)
              (setq nexts (cdr nexts)))
            ok))))

(defun dbms-wfg-deadlock-after-wait-p (requester holders)
  (let ((clean (dbms-lock-remove-txid-from-holders requester holders))
        (dead nil))
    (while (and (not dead) (not (null clean)))
      (if (dbms-wfg-path-exists-p (car clean) requester '())
          (setq dead t)
          nil)
      (setq clean (cdr clean)))
    dead))

(defun dbms-lock-make-conflict-or-deadlock (txid table-name holders message)
  (dbms-wfg-add-edges txid holders)
  (if (dbms-wfg-deadlock-after-wait-p txid holders)
      (dbms-make-error 'dbms/deadlock-detected "deadlock detected" (list table-name txid holders))
      (dbms-make-error 'dbms/lock-conflict message (list table-name txid holders))))

(defun dbms-lock-holders-only-tx-p (txid holders)
  (if (null holders)
      nil
      (let ((ok t)
            (rest holders))
        (while (and ok (not (null rest)))
          (if (= txid (car rest))
              nil
              (setq ok nil))
          (setq rest (cdr rest)))
        ok)))

(defun dbms-lock-acquire (txid table-name mode)
  (if (or (not (numberp txid)) (<= txid 0))
      (dbms-make-error 'dbms/invalid-representation "lock acquire requires txid>0" txid)
      (if (or (null table-name) (not (stringp table-name)) (string= table-name ""))
          (dbms-make-error 'dbms/invalid-representation "lock acquire requires table-name" table-name)
          (let ((entry (dbms-lock-find-entry table-name *dbms-lock-table*)))
            (if (null entry)
                (progn
                  (setq *dbms-lock-table* (dbms-lock-put-entry table-name mode (list txid) *dbms-lock-table*))
                  (dbms-wfg-clear-tx txid)
                  t)
                (let ((cur-mode (second entry))
                      (holders (third entry)))
                  (cond
                   ((eq mode 'S)
                    (if (eq cur-mode 'S)
                        (progn
                          (if (dbms-number-in-list-p txid holders)
                              nil
                              (setq holders (append holders (list txid))))
                            (setq *dbms-lock-table* (dbms-lock-put-entry table-name 'S holders *dbms-lock-table*))
                            (dbms-wfg-clear-tx txid)
                            t)
                        (if (dbms-number-in-list-p txid holders)
                            (progn
                              (dbms-wfg-clear-tx txid)
                              t)
                            (dbms-lock-make-conflict-or-deadlock txid table-name holders "S lock blocked by X lock"))))
                   ((eq mode 'X)
                    (if (eq cur-mode 'X)
                        (if (dbms-number-in-list-p txid holders)
                            (progn
                              (dbms-wfg-clear-tx txid)
                              t)
                            (dbms-lock-make-conflict-or-deadlock txid table-name holders "X lock held by other tx"))
                        (if (dbms-lock-holders-only-tx-p txid holders)
                            (progn
                              (setq *dbms-lock-table* (dbms-lock-put-entry table-name 'X (list txid) *dbms-lock-table*))
                              (dbms-wfg-clear-tx txid)
                              t)
                            (dbms-lock-make-conflict-or-deadlock txid table-name holders "X lock blocked by shared holders"))))
                   (t
                    (dbms-make-error 'dbms/invalid-representation "lock mode must be S or X" mode)))))))))

(defun dbms-lock-release-tx (txid)
  (let ((entries *dbms-lock-table*)
        (out '()))
    (while (not (null entries))
      (let* ((e (car entries))
             (table-name (first e))
             (mode (second e))
             (holders (third e))
             (new-holders (dbms-lock-remove-txid-from-holders txid holders)))
        (if (null new-holders)
            nil
            (setq out (append out (list (list table-name mode new-holders)))))
        (setq entries (cdr entries))))
    (setq *dbms-lock-table* out)
    (dbms-wfg-clear-tx txid)
    t))

(defun dbms-lock-release-shared-on-table (txid table-name)
  (let ((entry (dbms-lock-find-entry table-name *dbms-lock-table*)))
    (if (null entry)
        t
        (if (eq (second entry) 'S)
            (let ((holders (third entry))
                  (new-holders '()))
              (setq new-holders (dbms-lock-remove-txid-from-holders txid holders))
              (if (null new-holders)
                  (setq *dbms-lock-table* (dbms-lock-remove-entry table-name *dbms-lock-table*))
                  (setq *dbms-lock-table* (dbms-lock-put-entry table-name 'S new-holders *dbms-lock-table*)))
              t)
            ;; X lock is held by this tx (or someone else); keep it for tx boundary.
            t))))

(defun dbms-stmt-lock-mode (kind)
  (if (or (eq kind 'select)
          (eq kind 'explain))
      'S
      (if (or (eq kind 'insert)
              (eq kind 'update)
              (eq kind 'delete)
              (eq kind 'create-table)
              (eq kind 'create-table-wiki)
              (eq kind 'create-index)
              (eq kind 'alter-table)
              (eq kind 'analyze)
              (eq kind 'vacuum))
          'X
          '())))

(defun dbms-stmt-lock-target (stmt)
  (let* ((kind (second stmt))
         (table-name (dbms-stmt-table-name stmt)))
    (if (and (stringp table-name) (not (string= table-name "")))
        table-name
        (if (or (eq kind 'create-table)
                (eq kind 'create-table-wiki)
                (eq kind 'create-index)
                (eq kind 'alter-table)
                (eq kind 'analyze)
                (eq kind 'vacuum))
            "__catalog__"
            ""))))

(defun dbms-engine-lock-table-debug ()
  (dbms-lock-table-snapshot))

(defun dbms-find-staged-table-state-pair (table-name staged-states)
  (if (null staged-states)
      '()
      (let ((h (car staged-states)))
        (if (string= (first h) table-name)
            h
            (dbms-find-staged-table-state-pair table-name (cdr staged-states))))))

(defun dbms-put-staged-table-state (table-name state staged-states)
  (if (null staged-states)
      (list (list table-name state))
      (let ((h (car staged-states)))
        (if (string= (first h) table-name)
            (cons (list table-name state) (cdr staged-states))
            (cons h (dbms-put-staged-table-state table-name state (cdr staged-states)))))))

(defun dbms-engine-current-catalog ()
  (if (and (dbms-tx-active-p) (dbms-catalog-p *dbms-tx-staged-catalog*))
      *dbms-tx-staged-catalog*
      (dbms-catalog-load)))

(defun dbms-engine-save-catalog (catalog)
  (if (dbms-tx-active-p)
      (progn
        (setq *dbms-tx-staged-catalog* catalog)
        catalog)
      (dbms-catalog-save catalog)))

(defun dbms-engine-load-table-rows (table-name)
  (if (dbms-tx-active-p)
      (let ((pair (dbms-find-staged-table-state-pair table-name *dbms-tx-staged-table-states*)))
        (if (null pair)
            (let ((state (dbms-storage-load-table-rows table-name)))
              (if (dbms-error-p state)
                  state
                  (progn
                    (setq *dbms-tx-staged-table-states*
                          (dbms-put-staged-table-state table-name state *dbms-tx-staged-table-states*))
                    state)))
            (second pair)))
      (dbms-storage-load-table-rows table-name)))

(defun dbms-engine-save-table-rows (table-name rows)
  (if (dbms-tx-active-p)
      (let ((state (dbms-make-table-state table-name rows (+ (length rows) 1))))
        (setq *dbms-tx-staged-table-states*
              (dbms-put-staged-table-state table-name state *dbms-tx-staged-table-states*))
        state)
      (dbms-storage-save-table-rows table-name rows)))

(defun dbms-assoc-get (pairs key)
  (if (null pairs)
      '()
      (if (string= (first (first pairs)) key)
          (second (first pairs))
          (dbms-assoc-get (cdr pairs) key))))

(defun dbms-assoc-put (pairs key value)
  (if (null pairs)
      (list (list key value))
      (let ((h (car pairs)))
        (if (string= (first h) key)
            (cons (list key value) (cdr pairs))
            (cons h (dbms-assoc-put (cdr pairs) key value))))))

(defun dbms-table-indexes (table-def)
  (let ((opts (dbms-table-def-options table-def))
        (idxs '()))
    (setq idxs (dbms-assoc-get opts "indexes"))
    (if (listp idxs) idxs '())))

(defun dbms-index-entry-name (idx-entry)
  (dbms-assoc-get idx-entry "name"))

(defun dbms-index-entry-column (idx-entry)
  (dbms-assoc-get idx-entry "column"))

(defun dbms-table-find-index-by-name (indexes index-name)
  (if (null indexes)
      '()
      (if (string= (dbms-index-entry-name (car indexes)) index-name)
          (car indexes)
          (dbms-table-find-index-by-name (cdr indexes) index-name))))

(defun dbms-table-find-index-by-column (indexes col-name)
  (if (null indexes)
      '()
      (if (string= (dbms-index-entry-column (car indexes)) col-name)
          (car indexes)
          (dbms-table-find-index-by-column (cdr indexes) col-name))))

(defun dbms-table-def-with-indexes (table-def indexes)
  (let* ((opts (dbms-table-def-options table-def))
         (new-opts (dbms-assoc-put opts "indexes" indexes)))
    (dbms-make-table-def (dbms-table-def-name table-def)
                         (dbms-table-def-columns table-def)
                         (dbms-table-def-constraints table-def)
                         new-opts)))

(defun dbms-index-name-for-pk (table-name col-name)
  (string-append "__pk__" table-name "__" col-name))

(defun dbms-index-name-for-unique (table-name col-name)
  (string-append "__uq__" table-name "__" col-name))

(defun dbms-column-has-attr-p (column-def attr)
  (dbms-symbol-in-list-p attr (dbms-column-def-attrs column-def)))

(defun dbms-table-unique-columns-from-attrs (table-def)
  (let ((cols (dbms-table-def-columns table-def))
        (out '()))
    (dolist (c cols)
      (if (dbms-column-has-attr-p c 'UNIQUE)
          (setq out (append out (list (dbms-column-def-name c))))
          nil))
    out))

(defun dbms-string-in-list-p (s xs)
  (if (null xs)
      nil
      (if (string= s (car xs))
          t
          (dbms-string-in-list-p s (cdr xs)))))

(defun dbms-add-unique-string (xs s)
  (if (dbms-string-in-list-p s xs)
      xs
      (append xs (list s))))

(defun dbms-table-unique-columns-from-constraints (table-def)
  (let ((cons-list (dbms-table-def-constraints table-def))
        (out '()))
    (dolist (c cons-list)
      (if (and (eq (dbms-constraint-kind c) 'unique)
               (= (length (dbms-constraint-spec c)) 1)
               (stringp (first (dbms-constraint-spec c))))
          (setq out (dbms-add-unique-string out (first (dbms-constraint-spec c))))
          nil))
    out))

(defun dbms-table-pk-columns-for-index (table-def)
  (let ((cols (dbms-table-primary-key-columns table-def))
        (out '()))
    (dolist (c cols)
      (setq out (dbms-add-unique-string out c)))
    out))

(defun dbms-ensure-constraint-indexes-on-table-def (table-def)
  (let* ((table-name (dbms-table-def-name table-def))
         (indexes (dbms-table-indexes table-def))
         (pk-cols (dbms-table-pk-columns-for-index table-def))
         (uq-cols (dbms-table-unique-columns-from-attrs table-def))
         (uq2 (dbms-table-unique-columns-from-constraints table-def)))
    (dolist (c uq2)
      (setq uq-cols (dbms-add-unique-string uq-cols c)))
    (dolist (c pk-cols)
      (if (null (dbms-table-find-index-by-column indexes c))
          (setq indexes (append indexes
                                (list (list (list "name" (dbms-index-name-for-pk table-name c))
                                            (list "column" c)
                                            (list "kind" "btree")
                                            (list "unique" t)
                                            (list "implicit" "pk")))))
          nil))
    (dolist (c uq-cols)
      (if (null (dbms-table-find-index-by-column indexes c))
          (setq indexes (append indexes
                                (list (list (list "name" (dbms-index-name-for-unique table-name c))
                                            (list "column" c)
                                            (list "kind" "btree")
                                            (list "unique" t)
                                            (list "implicit" "unique")))))
          nil))
    (dbms-table-def-with-indexes table-def indexes)))

(defun dbms-engine-build-and-save-index (table-name index-name column-name rows)
  (let ((built (dbms-storage-build-btree-index table-name index-name column-name rows)))
    (if (dbms-error-p built)
        built
        (dbms-storage-save-index table-name index-name built))))

(defun dbms-engine-rebuild-table-indexes-from-def (table-name table-def rows)
  (let ((indexes (dbms-table-indexes table-def))
        (failed '()))
    (dolist (idx indexes)
      (if (dbms-error-p failed)
          nil
          (let ((saved (dbms-engine-build-and-save-index table-name
                                                         (dbms-index-entry-name idx)
                                                         (dbms-index-entry-column idx)
                                                         rows)))
            (if (dbms-error-p saved)
                (setq failed saved)
                nil))))
    (if (dbms-error-p failed) failed t)))

(defun dbms-predicate-simple-indexable-eq (pred)
  ;; Returns (<column-name> <literal-value> <literal-type>) for `=`.
  (if (or (null pred)
          (not (listp pred))
          (< (length pred) 4)
          (not (eq (first pred) 'dbms-predicate))
          (not (string= (third pred) "=")))
      '()
      (let ((expr (fourth pred)))
        (if (or (null expr)
                (not (listp expr))
                (< (length expr) 4)
                (not (eq (second expr) 'literal)))
            '()
            (if (eq (fourth expr) 'NULL)
                '()
                (list (second pred) (fourth expr) (third expr)))))))

(defun dbms-predicate-simple-indexable-range (pred)
  ;; Returns (<column-name> <op> <literal-value> <literal-type>) for < <= > >=.
  (if (or (null pred)
          (not (listp pred))
          (< (length pred) 4)
          (not (eq (first pred) 'dbms-predicate)))
      '()
      (let ((op (third pred))
            (expr (fourth pred)))
        (if (or (not (or (string= op "<")
                         (string= op "<=")
                         (string= op ">")
                         (string= op ">=")))
                (null expr)
                (not (listp expr))
                (< (length expr) 4)
                (not (eq (second expr) 'literal))
                (eq (fourth expr) 'NULL))
            '()
            (list (second pred) op (fourth expr) (third expr))))))

(defun dbms-row-id-in-list-p (rid ids)
  (if (null ids)
      nil
      (if (= rid (car ids))
          t
          (dbms-row-id-in-list-p rid (cdr ids)))))

(defun dbms-rows-filter-by-row-ids (rows ids)
  (let ((rest rows)
        (out '()))
    (while (not (null rest))
      (if (dbms-row-id-in-list-p (dbms-row-id (car rest)) ids)
          (setq out (append out (list (car rest))))
          nil)
      (setq rest (cdr rest)))
    out))

(defun dbms-find-row-by-id (rows rid)
  (if (null rows)
      '()
      (if (= (dbms-row-id (car rows)) rid)
          (car rows)
          (dbms-find-row-by-id (cdr rows) rid))))

(defun dbms-rows-by-row-ids-in-order (rows ids)
  (if (null ids)
      '()
      (let ((r (dbms-find-row-by-id rows (car ids))))
        (if (null r)
            (dbms-rows-by-row-ids-in-order rows (cdr ids))
            (cons r (dbms-rows-by-row-ids-in-order rows (cdr ids)))))))

(defun dbms-limit-rows (rows limit-n)
  (if (or (null limit-n) (not (numberp limit-n)) (<= limit-n 0))
      rows
      (dbms-list-take rows limit-n)))

(defun dbms-probe-type-compatible-p (table-cols col-name lit-type)
  (let ((col-def (dbms-find-column-def table-cols col-name)))
    (if (null col-def)
        nil
        (let ((col-type (dbms-column-def-type col-def)))
          (or (dbms-type-compatible-p col-type lit-type)
              (dbms-type-compatible-p lit-type col-type))))))

(defun dbms-predicate-range-bounds (pred)
  ;; Returns (<lower-key-or-nil> <lower-inclusive> <upper-key-or-nil> <upper-inclusive>)
  (let ((eqp (dbms-predicate-simple-indexable-eq pred))
        (rng (dbms-predicate-simple-indexable-range pred)))
    (if (not (null eqp))
        (list (second eqp) t (second eqp) t)
        (if (null rng)
            '()
            (let ((op (second rng))
                  (v (third rng)))
              (if (string= op ">")
                  (list v nil '() t)
                  (if (string= op ">=")
                      (list v t '() t)
                      (if (string= op "<")
                          (list '() t v nil)
                          (if (string= op "<=")
                              (list '() t v t)
                              '())))))))))

(defun dbms-index-rids-for-where (idx-data where-pred limit-n)
  (let ((eqp (dbms-predicate-simple-indexable-eq where-pred)))
    (if (not (null eqp))
        (dbms-storage-btree-search idx-data (second eqp))
        (if (null where-pred)
            (dbms-storage-btree-range-search idx-data '() t '() t limit-n)
            (let ((bounds (dbms-predicate-range-bounds where-pred)))
              (if (null bounds)
                  '()
                  (dbms-storage-btree-range-search idx-data
                                                  (first bounds)
                                                  (second bounds)
                                                  (third bounds)
                                                  (fourth bounds)
                                                  limit-n)))))))

(defun dbms-table-stats-from-def (table-def)
  (dbms-assoc-get (dbms-table-def-options table-def) "stats"))

(defun dbms-stats-row-count (stats fallback-row-count)
  (let ((n (dbms-assoc-get stats "row-count")))
    (if (and (numberp n) (>= n 0))
        n
        fallback-row-count)))

(defun dbms-stats-find-column-entry (col-stats col-name)
  (if (null col-stats)
      '()
      (if (string= (dbms-assoc-get (car col-stats) "name") col-name)
          (car col-stats)
          (dbms-stats-find-column-entry (cdr col-stats) col-name))))

(defun dbms-int-log2-ceil (n)
  (let ((x (if (< n 1) 1 n))
        (k 0)
        (v 1))
    (while (< v x)
      (setq v (* v 2))
      (setq k (+ k 1)))
    k))

(defun dbms-optimizer-estimate-selectivity (table-def scan-col eq-probe range-probe)
  (let* ((stats (dbms-table-stats-from-def table-def))
         (col-stats (dbms-assoc-get stats "columns"))
         (entry (dbms-stats-find-column-entry col-stats scan-col))
         (ndv (dbms-assoc-get entry "ndv")))
    (if (not (null eq-probe))
        (if (and (numberp ndv) (> ndv 0))
            (/ 1 ndv)
            0.1)
        (if (not (null range-probe))
            0.3
            1.0))))

(defun dbms-optimizer-choose-scan (table-def fallback-row-count can-use-index eq-probe range-probe order-col scan-col order-dir limit-n)
  (dbms-assoc-get (dbms-optimizer-plan-details table-def
                                               fallback-row-count
                                               can-use-index
                                               eq-probe
                                               range-probe
                                               order-col
                                               scan-col
                                               order-dir
                                               limit-n)
                  "scan-choice"))

(defun dbms-optimizer-plan-details (table-def fallback-row-count can-use-index eq-probe range-probe order-col scan-col order-dir limit-n)
  ;; Returns: "INDEX" | "SEQ"
  (if (not can-use-index)
      (list (list "scan-choice" "SEQ")
            (list "row-count" fallback-row-count)
            (list "selectivity" 1.0)
            (list "expected-rows" fallback-row-count)
            (list "seq-cost" fallback-row-count)
            (list "index-cost" 999999)
            (list "reason" "index-not-eligible"))
      (let* ((stats (dbms-table-stats-from-def table-def))
             (row-count (dbms-stats-row-count stats fallback-row-count))
             (sel (dbms-optimizer-estimate-selectivity table-def scan-col eq-probe range-probe))
             (expected-rows (if (<= row-count 0) 0 (truncate (* row-count sel))))
             (expected-rows (if (< expected-rows 1) 1 expected-rows))
             (limit-effective (and (numberp limit-n) (> limit-n 0)
                                   (or (null order-col)
                                       (string= order-col "")
                                       (and (string= order-col scan-col)
                                            (eq order-dir 'ASC)))))
             (rows-via-index (if limit-effective
                                 (if (< limit-n expected-rows) limit-n expected-rows)
                                 expected-rows))
             (seq-base row-count)
             (seq-sort (if (and (not (null order-col))
                                (not (string= order-col ""))
                                (> row-count 1))
                           (* row-count (dbms-int-log2-ceil row-count))
                           0))
             (seq-cost (+ seq-base seq-sort))
             (idx-seek (+ 1 (dbms-int-log2-ceil (if (> row-count 1) row-count 1))))
             (idx-fetch rows-via-index)
             (idx-sort (if (and (not (null order-col))
                                (not (string= order-col ""))
                                (not (string= order-col scan-col))
                                (> rows-via-index 1))
                           (* rows-via-index (dbms-int-log2-ceil rows-via-index))
                           0))
             (idx-cost (+ idx-seek idx-fetch idx-sort))
             (choice (if (<= row-count 64)
                         "SEQ"
                         (if (< idx-cost seq-cost) "INDEX" "SEQ"))))
        (list (list "scan-choice" choice)
              (list "row-count" row-count)
              (list "selectivity" sel)
              (list "expected-rows" expected-rows)
              (list "rows-via-index" rows-via-index)
              (list "seq-cost" seq-cost)
              (list "index-cost" idx-cost)
              (list "limit-effective" (if limit-effective "TRUE" "FALSE"))
              (list "reason" (if (string= choice "INDEX")
                                 "index-cost-lower"
                                 (if (<= row-count 64)
                                     "small-table-prefers-seq"
                                     "seq-cost-lower")))))))

(defun dbms-string-in-list-p (s xs)
  (if (null xs)
      nil
      (if (string= s (car xs))
          t
          (dbms-string-in-list-p s (cdr xs)))))

(defun dbms-set-union-strings (xs ys)
  (let ((out xs)
        (rest ys))
    (while (not (null rest))
      (if (dbms-string-in-list-p (car rest) out)
          nil
          (setq out (append out (list (car rest)))))
      (setq rest (cdr rest)))
    out))

(defun dbms-stmt-kind-write-p (kind)
  (or (eq kind 'insert)
      (eq kind 'update)
      (eq kind 'delete)
      (eq kind 'create-table)
      (eq kind 'create-table-wiki)
      (eq kind 'create-index)
      (eq kind 'alter-table)
      (eq kind 'analyze)
      (eq kind 'vacuum)))

(defun dbms-stmt-kind-read-p (kind)
  (or (eq kind 'select)
      (eq kind 'explain)))

(defun dbms-stmt-table-name (stmt)
  (let* ((kind (second stmt))
         (payload (third stmt))
         (inner (if (eq kind 'explain) (dbms-assoc-get payload "statement") '()))
         (inner-name (if (and (dbms-stmt-p inner))
                         (dbms-stmt-table-name inner)
                         '()))
         (name-a (dbms-assoc-get payload "table"))
         (name-b (dbms-assoc-get payload "table-name")))
    (if (and (eq kind 'explain)
             (stringp inner-name)
             (not (string= inner-name "")))
        inner-name
        (if (null name-a) name-b name-a))))

(defun dbms-tx-record-statement! (stmt)
  (if (eq (dbms-tx-state-status *dbms-tx-state*) 'active)
      (let* ((kind (second stmt))
             (table-name (dbms-stmt-table-name stmt))
             (add-set (if (or (null table-name) (not (stringp table-name)) (string= table-name ""))
                          '()
                          (list table-name)))
             (read-set (dbms-tx-state-read-set *dbms-tx-state*))
             (write-set (dbms-tx-state-write-set *dbms-tx-state*))
             (tx-id (dbms-tx-state-tx-id *dbms-tx-state*))
             (new-read (if (dbms-stmt-kind-read-p kind)
                           (dbms-set-union-strings read-set add-set)
                           read-set))
             (new-write (if (dbms-stmt-kind-write-p kind)
                            (dbms-set-union-strings write-set add-set)
                            write-set)))
        (setq *dbms-tx-state* (dbms-make-tx-state 'active new-read new-write tx-id)))
      nil))

(defun dbms-reverse (xs)
  (let ((rest xs)
        (out '()))
    (while (not (null rest))
      (setq out (cons (car rest) out))
      (setq rest (cdr rest)))
    out))

(defun dbms-list-take (xs n)
  (if (or (<= n 0) (null xs))
      '()
      (cons (car xs) (dbms-list-take (cdr xs) (- n 1)))))

(defun dbms-digits-only-p (s)
  (let ((i 0)
        (n (length s))
        (ok t))
    (if (= n 0)
        nil
        (progn
          (while (and ok (< i n))
            (let ((ch (substring s i (+ i 1))))
              (if (null (string-index ch "0123456789"))
                  (setq ok nil)
                  nil))
            (setq i (+ i 1)))
          ok))))

(defun dbms-test-commit-failpoint (tx-id)
  (let ((marker-path (getenv "DBMS_TEST_COMMIT_MARKER_PATH"))
        (delay-sec (getenv "DBMS_TEST_COMMIT_DELAY_SEC")))
    (if (and (not (null marker-path)) (not (string= marker-path "")))
        (with-open-file (s marker-path :direction :output :if-exists :overwrite :if-does-not-exist :create)
          (format s "tx=~A~%" tx-id))
        nil)
    (if (and (not (null delay-sec))
             (not (string= delay-sec ""))
             (dbms-digits-only-p delay-sec))
        (system (string-append "sleep " delay-sec))
        0)))

(defun dbms-find-column-def (columns name)
  (if (null columns)
      '()
      (let ((c (car columns)))
        (if (string= (dbms-column-def-name c) name)
            c
            (dbms-find-column-def (cdr columns) name)))))

(defun dbms-row-values (row)
  (third row))

(defun dbms-row-id (row)
  (second row))

(defun dbms-row-get-entry (row column-name)
  (let ((vals (dbms-row-values row)))
    (if (null vals)
        '()
        (let ((p (car vals)))
          (if (string= (first p) column-name)
              p
              (dbms-row-get-entry (list 'dbms-row 0 (cdr vals)) column-name))))))

(defun dbms-row-get-value (row column-name)
  (let ((entry (dbms-row-get-entry row column-name)))
    (if (null entry)
        'NULL
        (second entry))))

(defun dbms-column-type-check-p (col-type value)
  (if (eq value 'NULL)
      t
      (if (or (eq col-type 'INT)
              (eq col-type 'INTEGER)
              (eq col-type 'BIGINT)
              (eq col-type 'BIGSERIAL))
          (numberp value)
          (if (eq col-type 'TEXT)
              (stringp value)
              (if (eq col-type 'BOOL)
                  (or (eq value t) (null value))
                  (if (eq col-type 'TIMESTAMPTZ)
                      (or (numberp value) (stringp value))
                      nil))))))

(defun dbms-ascii-downcase-char (ch)
  (let ((p (string-index ch "ABCDEFGHIJKLMNOPQRSTUVWXYZ")))
    (if (null p)
        ch
        (substring "abcdefghijklmnopqrstuvwxyz" p (+ p 1)))))

(defun dbms-ascii-downcase (s)
  (let ((i 0)
        (n (length s))
        (out ""))
    (while (< i n)
      (setq out (string-append out (dbms-ascii-downcase-char (substring s i (+ i 1)))))
      (setq i (+ i 1)))
    out))

(defun dbms-fn-lower (v)
  (if (stringp v)
      (dbms-ascii-downcase v)
      '()))

(defun dbms-fn-position (substr txt)
  (if (or (not (stringp substr)) (not (stringp txt)))
      '()
      (let ((p (string-index substr txt)))
        (if (null p) 0 (+ p 1)))))

(defun dbms-fn-coalesce (vals)
  (if (null vals)
      'NULL
      (if (eq (car vals) 'NULL)
          (dbms-fn-coalesce (cdr vals))
          (car vals))))

(defun dbms-max-value2 (a b)
  (if (eq a 'NULL)
      b
      (if (eq b 'NULL)
          a
          (if (and (numberp a) (numberp b))
              (if (> a b) a b)
              (if (and (stringp a) (stringp b))
                  (if (string> a b) a b)
                  a)))))

(defun dbms-fn-max (vals)
  (if (null vals)
      'NULL
      (let ((rest (cdr vals))
            (acc (car vals)))
        (while (not (null rest))
          (setq acc (dbms-max-value2 acc (car rest)))
          (setq rest (cdr rest)))
        acc)))

(defun dbms-fn-to-char (ts fmt)
  (if (not (and (stringp fmt) (string= fmt "YYYY-MM-DD HH24:MI:SS")))
      '()
      (if (stringp ts)
          (if (>= (length ts) 19)
              (substring ts 0 19)
              ts)
          (if (numberp ts)
              (format nil "~A" ts)
              '()))))

(defun dbms-infer-value-type (v)
  (if (eq v 'NULL)
      'NULL
      (if (stringp v)
          'TEXT
          (if (numberp v)
              'INT
              (if (or (eq v t) (null v))
                  'BOOL
                  'UNKNOWN)))))

(defun dbms-numeric-type-p (ty)
  (or (eq ty 'INT)
      (eq ty 'INTEGER)
      (eq ty 'BIGINT)
      (eq ty 'BIGSERIAL)))

(defun dbms-type-compatible-p (target-type value-type)
  (or (eq value-type 'NULL)
      (eq target-type value-type)
      (and (dbms-numeric-type-p target-type)
           (dbms-numeric-type-p value-type))
      (and (eq target-type 'TIMESTAMPTZ) (eq value-type 'TEXT))
      (and (eq target-type 'TIMESTAMPTZ) (dbms-numeric-type-p value-type))))

(defun dbms-eval-function (name args-evaluated)
  ;; args-evaluated: ((type value) ...)
  (let ((vals (mapcar (lambda (x) (second x)) args-evaluated)))
    (if (string= name "LOWER")
        (if (= (length vals) 1)
            (let ((v (dbms-fn-lower (first vals))))
              (if (null v)
                  (dbms-make-error 'dbms/type-mismatch "LOWER requires TEXT" vals)
                  (list 'TEXT v)))
            (dbms-make-error 'dbms/parse-error "LOWER arity mismatch" vals))
        (if (string= name "POSITION")
            (if (= (length vals) 2)
                (let ((v (dbms-fn-position (first vals) (second vals))))
                  (if (null v)
                      (dbms-make-error 'dbms/type-mismatch "POSITION requires TEXT,TEXT" vals)
                      (list 'INT v)))
                (dbms-make-error 'dbms/parse-error "POSITION arity mismatch" vals))
            (if (string= name "COALESCE")
                (let ((v (dbms-fn-coalesce vals)))
                  (list (dbms-infer-value-type v) v))
                (if (string= name "MAX")
                    (let ((v (dbms-fn-max vals)))
                      (list (dbms-infer-value-type v) v))
                    (if (string= name "TO_CHAR")
                        (if (= (length vals) 2)
                            (let ((v (dbms-fn-to-char (first vals) (second vals))))
                              (if (null v)
                                  (dbms-make-error 'dbms/type-mismatch "TO_CHAR requires (TIMESTAMPTZ,TEXT format)" vals)
                                  (list 'TEXT v)))
                            (dbms-make-error 'dbms/parse-error "TO_CHAR arity mismatch" vals))
                        (dbms-make-error 'dbms/not-implemented "unknown function" name))))))))

(defun dbms-expr-result-type (expr row table-columns)
  (let ((kind (second expr)))
    (if (eq kind 'literal)
        (third expr)
        (if (eq kind 'identifier)
            (let ((col (dbms-find-column-def table-columns (third expr))))
              (if (null col)
                  'UNKNOWN
                  (dbms-column-def-type col)))
            'UNKNOWN))))

(defun dbms-eval-expr (expr row table-columns)
  (let ((kind (second expr)))
    (if (eq kind 'literal)
        (list (third expr) (fourth expr))
        (if (eq kind 'identifier)
            (let* ((name (third expr))
                   (col (dbms-find-column-def table-columns name)))
              (if (null col)
                  (dbms-make-error 'dbms/column-not-found "column not found in expression" name)
                  (list (dbms-column-def-type col)
                        (dbms-row-get-value row name))))
            (if (eq kind 'function)
                (let ((name (third expr))
                      (args (fourth expr))
                      (vals '())
                      (failed '()))
                  (dolist (a args)
                    (if (dbms-error-p failed)
                        nil
                        (let ((ev (dbms-eval-expr a row table-columns)))
                          (if (dbms-error-p ev)
                              (setq failed ev)
                              (setq vals (append vals (list ev)))))))
                  (if (dbms-error-p failed)
                      failed
                      (dbms-eval-function name vals)))
                (dbms-make-error 'dbms/parse-error "unsupported expression kind" kind))))))

(defun dbms-compare-values (op left right)
  (if (or (eq left 'NULL) (eq right 'NULL))
      nil
      (if (string= op "=")
          (equal left right)
          (if (string= op "!=")
              (not (equal left right))
              (if (string= op "<>")
                  (not (equal left right))
                  (if (string= op "<")
                      (< left right)
                      (if (string= op "<=")
                          (<= left right)
                          (if (string= op ">")
                              (> left right)
                              (if (string= op ">=")
                                  (>= left right)
                                  nil)))))))))

(defun dbms-eval-predicate (pred row table-columns)
  (if (null pred)
      t
      (let* ((col-name (second pred))
             (op (third pred))
             (rhs-expr (fourth pred))
             (col-def (dbms-find-column-def table-columns col-name)))
        (if (null col-def)
            (dbms-make-error 'dbms/column-not-found "column not found" col-name)
            (let* ((left-type (dbms-column-def-type col-def))
                   (left-val (dbms-row-get-value row col-name))
                   (rhs (dbms-eval-expr rhs-expr row table-columns)))
              (if (dbms-error-p rhs)
                  rhs
                  (let ((right-type (first rhs))
                        (right-val (second rhs)))
                    (if (or (dbms-type-compatible-p left-type right-type)
                            (dbms-type-compatible-p right-type left-type))
                        (dbms-compare-values op left-val right-val)
                        (dbms-make-error 'dbms/type-mismatch "predicate type mismatch" (list left-type right-type))))))))))

(defun dbms-col-not-null-p (col)
  (dbms-symbol-in-list-p 'NOT-NULL (dbms-column-def-attrs col)))

(defun dbms-col-primary-key-p (col)
  (dbms-symbol-in-list-p 'PRIMARY-KEY (dbms-column-def-attrs col)))

(defun dbms-col-default-now-p (col)
  (dbms-symbol-in-list-p 'DEFAULT-NOW (dbms-column-def-attrs col)))

(defun dbms-current-timestamptz ()
  (format nil "~A" (get-universal-time)))

(defun dbms-table-primary-key-columns (table-def)
  (let ((cols (dbms-table-def-columns table-def))
        (out '()))
    (while (not (null cols))
      (if (dbms-col-primary-key-p (car cols))
          (setq out (append out (list (dbms-column-def-name (car cols)))))
          nil)
      (setq cols (cdr cols)))
    out))

(defun dbms-row-violates-not-null (row columns)
  (if (null columns)
      '()
      (let ((col (car columns))
            (rest (cdr columns)))
        (if (and (dbms-col-not-null-p col)
                 (eq (dbms-row-get-value row (dbms-column-def-name col)) 'NULL))
            (dbms-column-def-name col)
            (dbms-row-violates-not-null row rest)))))

(defun dbms-unique-constraint-targets (table-def)
  ;; Returns: (("PK" <col>) ("UNIQUE" <col>) ...)
  (let ((targets '())
        (pk-cols (dbms-table-pk-columns-for-index table-def))
        (uq-cols (dbms-table-unique-columns-from-attrs table-def))
        (uq2 (dbms-table-unique-columns-from-constraints table-def)))
    (dolist (c pk-cols)
      (setq targets (append targets (list (list "PK" c)))))
    (dolist (c uq2)
      (setq uq-cols (dbms-add-unique-string uq-cols c)))
    (dolist (c uq-cols)
      (if (dbms-string-in-list-p c pk-cols)
          nil
          (setq targets (append targets (list (list "UNIQUE" c))))))
    targets))

(defun dbms-validate-unique-target-via-index (rows target)
  (let* ((kind (first target))
         (col-name (second target))
         (idx (dbms-storage-btree-new-index "__validate__" "__validate__" col-name))
         (rest rows)
         (failed '()))
    (while (and (null failed) (not (null rest)))
      (let* ((row (car rest))
             (rid (dbms-row-id row))
             (key (dbms-row-get-value row col-name))
             (skip-null (and (string= kind "UNIQUE") (eq key 'NULL))))
        (if skip-null
            nil
            (let ((hits (dbms-storage-btree-search idx key)))
              (if (dbms-error-p hits)
                  (setq failed hits)
                  (if (not (null hits))
                      (if (string= kind "PK")
                          (setq failed (dbms-make-error 'dbms/primary-key-violation "PRIMARY KEY violation" col-name))
                          (setq failed (dbms-make-error 'dbms/primary-key-violation "UNIQUE violation" col-name)))
                      (let ((next (dbms-storage-btree-insert idx key rid)))
                        (if (dbms-error-p next)
                            (setq failed next)
                            (setq idx next))))))))
      (setq rest (cdr rest)))
    (if (dbms-error-p failed) failed t)))

(defun dbms-validate-unique-via-index (rows table-def)
  (let ((targets (dbms-unique-constraint-targets table-def))
        (failed '()))
    (dolist (tgt targets)
      (if (dbms-error-p failed)
          nil
          (let ((r (dbms-validate-unique-target-via-index rows tgt)))
            (if (dbms-error-p r)
                (setq failed r)
                nil))))
    (if (dbms-error-p failed) failed t)))

(defun dbms-sql-token-p (x)
  (and (listp x) (not (null x)) (eq (car x) 'dbms-sql-token)))

(defun dbms-token-list-p (xs)
  (if (null xs)
      nil
      (dbms-sql-token-p (car xs))))

(defun dbms-all-null-p (vals)
  (if (null vals)
      t
      (if (eq (car vals) 'NULL)
          (dbms-all-null-p (cdr vals))
          nil)))

(defun dbms-any-null-p (vals)
  (if (null vals)
      nil
      (if (eq (car vals) 'NULL)
          t
          (dbms-any-null-p (cdr vals)))))

(defun dbms-values-equal-list-p (a b)
  (if (null a)
      t
      (if (equal (car a) (car b))
          (dbms-values-equal-list-p (cdr a) (cdr b))
          nil)))

(defun dbms-row-values-by-cols (row col-names)
  (if (null col-names)
      '()
      (cons (dbms-row-get-value row (car col-names))
            (dbms-row-values-by-cols row (cdr col-names)))))

(defun dbms-row-check-constraint (catalog table-def row constraint)
  (let ((kind (dbms-constraint-kind constraint))
        (spec (dbms-constraint-spec constraint))
        (cols (dbms-table-def-columns table-def)))
    (if (eq kind 'check)
        (if (dbms-token-list-p spec)
            (let ((p (dbms-parse-predicate spec)))
              (if (dbms-error-p p)
                  (dbms-make-error 'dbms/type-mismatch "unsupported CHECK expression" spec)
                  (let ((ok (dbms-eval-predicate (dbms-parser-ok-value p) row cols)))
                    (if (dbms-error-p ok)
                        ok
                        (if ok t (dbms-make-error 'dbms/type-mismatch "CHECK constraint failed" (dbms-constraint-name constraint)))))))
            ;; 既存の symbolic spec は現状互換で許容。
            t)
        (if (eq kind 'foreign-key)
            (let* ((local-cols (first spec))
                   (ref-table (second spec))
                   (ref-cols (third spec))
                   (local-vals (dbms-row-values-by-cols row local-cols)))
              (if (dbms-any-null-p local-vals)
                  t
                  (let* ((ref-def (dbms-catalog-find-table catalog ref-table))
                         (ref-state (if (null ref-def) '() (dbms-engine-load-table-rows ref-table)))
                         (ref-rows (if (or (null ref-def) (dbms-error-p ref-state)) '() (third ref-state)))
                         (found nil))
                    (dolist (rr ref-rows)
                      (if (dbms-values-equal-list-p local-vals (dbms-row-values-by-cols rr ref-cols))
                          (setq found t)
                          nil))
                    (if found
                        t
                        (dbms-make-error 'dbms/table-not-found "FOREIGN KEY reference not found" (list local-cols local-vals ref-table ref-cols))))))
            t))))

(defun dbms-validate-row-type (row columns)
  (if (null columns)
      t
      (let* ((col (car columns))
             (name (dbms-column-def-name col))
             (ty (dbms-column-def-type col))
             (v (dbms-row-get-value row name)))
        (if (dbms-column-type-check-p ty v)
            (dbms-validate-row-type row (cdr columns))
            (dbms-make-error 'dbms/type-mismatch "value does not match column type" (list name ty v))))))

(defun dbms-validate-rows (rows table-def catalog)
  (let ((cols (dbms-table-def-columns table-def))
        (constraints (dbms-table-def-constraints table-def))
        (rest rows)
        (err '()))
    (while (and (null err) (not (null rest)))
      (let* ((row (car rest))
             (type-check (dbms-validate-row-type row cols))
             (nn-violation (if (dbms-error-p type-check)
                               '()
                               (dbms-row-violates-not-null row cols))))
        (if (dbms-error-p type-check)
            (setq err type-check)
            (if (null nn-violation)
                nil
                (setq err (dbms-make-error 'dbms/not-null-violation "NOT NULL violation" nn-violation)))))
      (setq rest (cdr rest)))
    (if (dbms-error-p err)
        err
        (let ((uniq-check (dbms-validate-unique-via-index rows table-def)))
          (if (dbms-error-p uniq-check)
              uniq-check
            (let ((rr rows))
              (while (and (not (null rr)) (null err))
                (dolist (c constraints)
                  (if (and (null err) (not (dbms-error-p err)))
                      (let ((chk (dbms-row-check-constraint catalog table-def (car rr) c)))
                        (if (dbms-error-p chk)
                            (setq err chk)
                            nil))
                      nil))
                (setq rr (cdr rr)))
              (if (dbms-error-p err) err t))
            )))))

(defun dbms-next-row-id (rows)
  (let ((rest rows)
        (mx 0))
    (while (not (null rest))
      (let ((rid (dbms-row-id (car rest))))
        (if (> rid mx)
            (setq mx rid)
            nil))
      (setq rest (cdr rest)))
    (+ mx 1)))

(defun dbms-next-serial-for-column (rows col-name)
  (let ((rest rows)
        (mx 0))
    (while (not (null rest))
      (let ((v (dbms-row-get-value (car rest) col-name)))
        (if (and (numberp v) (> v mx))
            (setq mx v)
            nil))
      (setq rest (cdr rest)))
    (+ mx 1)))

(defun dbms-build-row-values-for-columns (rows columns input-col-names exprs table-columns)
  (let ((rest-cols columns)
        (rest-input input-col-names)
        (rest-exprs exprs)
        (row-scratch (dbms-make-row 0 '()))
        (pairs '())
        (failed '()))
    ;; columns 指定なしは定義順で値を割り当て。
    (if (null input-col-names)
        (setq rest-input (mapcar (lambda (c) (dbms-column-def-name c)) columns))
        nil)
    (if (not (= (length rest-input) (length rest-exprs)))
        (setq failed (dbms-make-error 'dbms/arity-mismatch "column/value count mismatch" (list (length rest-input) (length rest-exprs))))
        nil)
    (while (and (null failed) (not (null rest-input)))
      (let* ((col-name (car rest-input))
             (expr (car rest-exprs))
             (col-def (dbms-find-column-def table-columns col-name)))
        (if (null col-def)
            (setq failed (dbms-make-error 'dbms/column-not-found "column not found" col-name))
            (let* ((ev (dbms-eval-expr expr row-scratch table-columns))
                   (target-type (dbms-column-def-type col-def)))
              (if (dbms-error-p ev)
                  (setq failed ev)
                  (let ((et (first ev))
                        (evv (second ev)))
                    (if (dbms-type-compatible-p target-type et)
                        (setq pairs (append pairs (list (list col-name evv))))
                        (setq failed (dbms-make-error 'dbms/type-mismatch "insert value type mismatch" (list col-name target-type et)))))))))
      (setq rest-input (cdr rest-input))
      (setq rest-exprs (cdr rest-exprs)))

    ;; 未指定列は NULL を入れる。
    (while (and (null failed) (not (null rest-cols)))
      (let* ((col (car rest-cols))
             (name (dbms-column-def-name col))
             (ty (dbms-column-def-type col)))
        (if (null (dbms-row-get-entry (dbms-make-row 0 pairs) name))
            (if (eq ty 'BIGSERIAL)
                (setq pairs (append pairs (list (list name (dbms-next-serial-for-column rows name)))))
                (if (dbms-col-default-now-p col)
                    (setq pairs (append pairs (list (list name (dbms-current-timestamptz)))))
                    (setq pairs (append pairs (list (list name 'NULL))))))
            nil))
      (setq rest-cols (cdr rest-cols)))

    (if (dbms-error-p failed)
        failed
        pairs)))

(defun dbms-row-values-get (pairs key)
  (if (null pairs)
      '()
      (if (string= (first (first pairs)) key)
          (second (first pairs))
          (dbms-row-values-get (cdr pairs) key))))

(defun dbms-row-values-set (pairs key value)
  (if (null pairs)
      (list (list key value))
      (let ((h (car pairs)))
        (if (string= (first h) key)
            (cons (list key value) (cdr pairs))
            (cons h (dbms-row-values-set (cdr pairs) key value))))))

(defun dbms-set-pairs-contains-column-p (set-pairs column-name)
  (if (null set-pairs)
      nil
      (if (string= (first (car set-pairs)) column-name)
          t
          (dbms-set-pairs-contains-column-p (cdr set-pairs) column-name))))

(defun dbms-should-auto-touch-updated-at-p (table-name table-cols set-pairs)
  (if (not (string= table-name "pages"))
      nil
      (if (dbms-set-pairs-contains-column-p set-pairs "updated_at")
          nil
          (let ((col (dbms-find-column-def table-cols "updated_at")))
            (and (not (null col))
                 (eq (dbms-column-def-type col) 'TIMESTAMPTZ))))))

(defun dbms-rows-filter-by-predicate (rows pred table-columns)
  (let ((rest rows)
        (out '())
        (failed '()))
    (while (and (null failed) (not (null rest)))
      (let ((ok (dbms-eval-predicate pred (car rest) table-columns)))
        (if (dbms-error-p ok)
            (setq failed ok)
            (if ok
                (setq out (append out (list (car rest))))
                nil)))
      (setq rest (cdr rest)))
    (if (dbms-error-p failed)
        failed
        out)))

(defun dbms-bool-value-p (v)
  (or (eq v t) (null v)))

(defun dbms-compare-order-values (a b)
  (if (and (eq a 'NULL) (eq b 'NULL))
      0
      (if (eq a 'NULL)
          1
          (if (eq b 'NULL)
              -1
              (if (and (numberp a) (numberp b))
                  (if (< a b) -1 (if (> a b) 1 0))
                  (if (and (stringp a) (stringp b))
                      (if (string< a b) -1 (if (string> a b) 1 0))
                      (if (and (dbms-bool-value-p a) (dbms-bool-value-p b))
                          (let ((ia (if (eq a t) 1 0))
                                (ib (if (eq b t) 1 0)))
                            (if (< ia ib) -1 (if (> ia ib) 1 0)))
                          0)))))))

(defun dbms-order-row-before-p (row-a row-b order-col order-dir)
  (let* ((va (dbms-row-get-value row-a order-col))
         (vb (dbms-row-get-value row-b order-col))
         (cmp (dbms-compare-order-values va vb)))
    (if (eq order-dir 'DESC)
        (> cmp 0)
        (< cmp 0))))

(defun dbms-stable-order-insert (row sorted order-col order-dir)
  (if (null sorted)
      (list row)
      (if (dbms-order-row-before-p row (car sorted) order-col order-dir)
          (cons row sorted)
          (cons (car sorted) (dbms-stable-order-insert row (cdr sorted) order-col order-dir)))))

(defun dbms-stable-order-rows (rows order-col order-dir)
  (let ((rest rows)
        (sorted '()))
    (while (not (null rest))
      (setq sorted (dbms-stable-order-insert (car rest) sorted order-col order-dir))
      (setq rest (cdr rest)))
    sorted))

(defun dbms-row-project (row columns)
  (if (null columns)
      '()
      (cons (dbms-row-get-value row (car columns))
            (dbms-row-project row (cdr columns)))))

(defun dbms-value-in-list-p (v xs)
  (if (null xs)
      nil
      (if (equal v (car xs))
          t
          (dbms-value-in-list-p v (cdr xs)))))

(defun dbms-column-stats (rows col-name)
  (let ((rest rows)
        (row-count 0)
        (null-count 0)
        (distinct '()))
    (while (not (null rest))
      (let ((v (dbms-row-get-value (car rest) col-name)))
        (setq row-count (+ row-count 1))
        (if (eq v 'NULL)
            (setq null-count (+ null-count 1))
            (if (dbms-value-in-list-p v distinct)
                nil
                (setq distinct (append distinct (list v))))))
      (setq rest (cdr rest)))
    (list (list "name" col-name)
          (list "ndv" (length distinct))
          (list "null-fraction" (if (= row-count 0) 0 (/ null-count row-count))))))

(defun dbms-table-stats (rows columns)
  (let ((col-rest columns)
        (col-stats '()))
    (while (not (null col-rest))
      (setq col-stats (append col-stats
                              (list (dbms-column-stats rows (dbms-column-def-name (car col-rest))))))
      (setq col-rest (cdr col-rest)))
    (list (list "row-count" (length rows))
          (list "columns" col-stats))))

(defun dbms-table-def-with-stats (table-def stats)
  (let* ((opts (dbms-table-def-options table-def))
         (new-opts (dbms-assoc-put opts "stats" stats)))
    (dbms-make-table-def (dbms-table-def-name table-def)
                         (dbms-table-def-columns table-def)
                         (dbms-table-def-constraints table-def)
                         new-opts)))

(defun dbms-engine-analyze (catalog stmt)
  (let* ((payload (third stmt))
         (target (dbms-assoc-get payload "table"))
         (table-names (if (or (null target) (not (stringp target)) (string= target ""))
                          (dbms-catalog-table-names catalog)
                          (list target)))
         (cur catalog)
         (rest table-names)
         (failed '()))
    (while (and (null failed) (not (null rest)))
      (let* ((name (car rest))
             (table-def (dbms-catalog-find-table cur name)))
        (if (null table-def)
            (setq failed (dbms-make-error 'dbms/table-not-found "table not found" name))
            (let ((state (dbms-engine-load-table-rows name)))
              (if (dbms-error-p state)
                  (setq failed state)
                  (let* ((rows (third state))
                         (stats (dbms-table-stats rows (dbms-table-def-columns table-def)))
                         (updated (dbms-table-def-with-stats table-def stats))
                         (replaced (dbms-catalog-replace-table-def cur updated)))
                    (if (dbms-error-p replaced)
                        (setq failed replaced)
                        (setq cur replaced)))))))
      (setq rest (cdr rest)))
    (if (dbms-error-p failed)
        (dbms-make-result 'error failed)
        (let ((saved (dbms-engine-save-catalog cur)))
          (if (dbms-error-p saved)
              (dbms-make-result 'error saved)
              (dbms-make-result-ok 'ok))))))

(defun dbms-engine-vacuum-report-row (report)
  (let* ((table-name (dbms-assoc-get report "table"))
         (before (dbms-assoc-get report "before"))
         (after (dbms-assoc-get report "after"))
         (before-frag (dbms-assoc-get before "fragmentation-ratio"))
         (after-frag (dbms-assoc-get after "fragmentation-ratio"))
         (before-empty (dbms-assoc-get before "empty-page-count"))
         (after-empty (dbms-assoc-get after "empty-page-count"))
         (before-dead (dbms-assoc-get before "dead-tuple-count"))
         (after-dead (dbms-assoc-get after "dead-tuple-count")))
    (list (list table-name
                before-frag
                after-frag
                (- before-empty after-empty)
                (- before-dead after-dead)))))

(defun dbms-engine-vacuum (catalog stmt)
  (if (dbms-tx-active-p)
      (dbms-make-result-error 'dbms/not-implemented "VACUUM in active transaction is not supported" 'VACUUM)
      (let* ((payload (third stmt))
             (target (dbms-assoc-get payload "table"))
             (table-names (if (or (null target) (not (stringp target)) (string= target ""))
                              (dbms-catalog-table-names catalog)
                              (list target)))
             (rest table-names)
             (failed '())
             (rows '()))
        (while (and (null failed) (not (null rest)))
          (let ((name (car rest))
                (table-def (dbms-catalog-find-table catalog (car rest))))
            (if (null table-def)
                (setq failed (dbms-make-error 'dbms/table-not-found "table not found" name))
                (let ((report (dbms-storage-vacuum-table-pages name)))
                  (if (dbms-error-p report)
                      (setq failed report)
                      (setq rows (append rows (dbms-engine-vacuum-report-row report)))))))
          (setq rest (cdr rest)))
        (if (dbms-error-p failed)
            (dbms-make-result 'error failed)
            (dbms-make-result-rows
             '("table" "before-frag" "after-frag" "reclaimed-pages" "reclaimed-dead-tuples")
             rows)))))

(defun dbms-explain-rows-for-select (table-name scan-col idx-entry plan-details where-pred order-by limit-n)
  (list (list "target-table" table-name)
        (list "scan-column" scan-col)
        (list "index-name" (if (null idx-entry) "N/A" (dbms-index-entry-name idx-entry)))
        (list "where" (format nil "~A" where-pred))
        (list "order-by" (format nil "~A" order-by))
        (list "limit" (format nil "~A" limit-n))
        (list "scan-choice" (dbms-assoc-get plan-details "scan-choice"))
        (list "reason" (dbms-assoc-get plan-details "reason"))
        (list "row-count" (dbms-assoc-get plan-details "row-count"))
        (list "selectivity" (dbms-assoc-get plan-details "selectivity"))
        (list "expected-rows" (dbms-assoc-get plan-details "expected-rows"))
        (list "rows-via-index" (dbms-assoc-get plan-details "rows-via-index"))
        (list "seq-cost" (dbms-assoc-get plan-details "seq-cost"))
        (list "index-cost" (dbms-assoc-get plan-details "index-cost"))
        (list "limit-effective" (dbms-assoc-get plan-details "limit-effective"))))

(defun dbms-engine-explain-select (catalog stmt)
  (let* ((payload (third stmt))
         (table-name (dbms-assoc-get payload "table"))
         (where-pred (dbms-assoc-get payload "where"))
         (order-by (dbms-assoc-get payload "order-by"))
         (limit-n (dbms-assoc-get payload "limit"))
         (table-def (dbms-catalog-find-table catalog table-name)))
    (if (null table-def)
        (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
        (let* ((state (dbms-engine-load-table-rows table-name))
               (all-rows (third state))
               (table-cols (dbms-table-def-columns table-def))
               (eq-probe (dbms-predicate-simple-indexable-eq where-pred))
               (range-probe (dbms-predicate-simple-indexable-range where-pred))
               (order-col (if (null order-by) "" (first order-by)))
               (order-dir (if (null order-by) 'ASC (second order-by)))
               (scan-col (if (and (not (null range-probe)) (stringp (first range-probe)))
                             (first range-probe)
                             (if (and (not (null eq-probe)) (stringp (first eq-probe)))
                                 (first eq-probe)
                                 (if (null order-by) "" order-col))))
               (idx-entry (if (or (dbms-tx-active-p) (string= scan-col ""))
                              '()
                              (dbms-table-find-index-by-column (dbms-table-indexes table-def) scan-col)))
               (idx-data (if (null idx-entry)
                             '()
                             (dbms-storage-load-index table-name (dbms-index-entry-name idx-entry))))
               (probe-type-ok (if (not (null eq-probe))
                                  (dbms-probe-type-compatible-p table-cols (first eq-probe) (third eq-probe))
                                  (if (not (null range-probe))
                                      (dbms-probe-type-compatible-p table-cols (first range-probe) (fourth range-probe))
                                      t)))
               (index-eligible (and (not (dbms-tx-active-p))
                                    (not (null idx-entry))
                                    (dbms-btree-index-p idx-data)
                                    probe-type-ok
                                    (or (null where-pred)
                                        (and (not (null eq-probe))
                                             (string= scan-col (first eq-probe)))
                                        (and (not (null range-probe))
                                             (string= scan-col (first range-probe))))))
               (plan-details (dbms-optimizer-plan-details table-def
                                                          (length all-rows)
                                                          index-eligible
                                                          eq-probe
                                                          range-probe
                                                          order-col
                                                          scan-col
                                                          order-dir
                                                          limit-n))
               (rows (dbms-explain-rows-for-select table-name scan-col idx-entry plan-details where-pred order-by limit-n)))
          (dbms-make-result-rows '("item" "value") rows)))))

(defun dbms-engine-explain (catalog stmt)
  (let* ((inner (dbms-assoc-get (third stmt) "statement"))
         (kind (if (dbms-stmt-p inner) (second inner) '())))
    (if (eq kind 'select)
        (dbms-engine-explain-select catalog inner)
        (dbms-make-result-error 'dbms/not-implemented "EXPLAIN supports SELECT only in P3-007" kind))))

(defun dbms-engine-create-table (catalog stmt)
  (let* ((table-def (third stmt))
         (created (dbms-catalog-create-table catalog table-def)))
    (if (dbms-error-p created)
        (dbms-make-result 'error created)
        (let* ((normalized (dbms-catalog-find-table created (dbms-table-def-name table-def)))
               (table-def2 (if (null normalized)
                               table-def
                               (dbms-ensure-constraint-indexes-on-table-def normalized)))
               (catalog2 (dbms-catalog-replace-table-def created table-def2)))
          (if (dbms-error-p catalog2)
              (dbms-make-result 'error catalog2)
              (let ((saved-catalog (dbms-engine-save-catalog catalog2))
                    (saved-table (dbms-engine-save-table-rows (dbms-table-def-name table-def2) '()))
                    (saved-idx (if (dbms-tx-active-p)
                                   t
                                   (dbms-engine-rebuild-table-indexes-from-def (dbms-table-def-name table-def2) table-def2 '()))))
                (if (dbms-error-p saved-catalog)
                    (dbms-make-result 'error saved-catalog)
                    (if (dbms-error-p saved-table)
                        (dbms-make-result 'error saved-table)
                        (if (dbms-error-p saved-idx)
                            (dbms-make-result 'error saved-idx)
                            (dbms-make-result-ok 'ok))))))))))

(defun dbms-engine-create-table-wiki (catalog stmt)
  (let* ((payload (third stmt))
         (table-def (dbms-assoc-get payload "table-def"))
         (if-not-exists (dbms-assoc-get payload "if-not-exists"))
         (exists (dbms-catalog-find-table catalog (dbms-table-def-name table-def))))
    (if (and (not (null exists)) if-not-exists)
        (dbms-make-result-ok 'ok)
        (dbms-engine-create-table catalog (dbms-make-stmt 'create-table table-def)))))

(defun dbms-engine-create-index (catalog stmt)
  (let* ((payload (third stmt))
         (index-name (dbms-assoc-get payload "index-name"))
         (table-name (dbms-assoc-get payload "table"))
         (columns (dbms-assoc-get payload "columns"))
         (if-not-exists (dbms-assoc-get payload "if-not-exists"))
         (table-def (dbms-catalog-find-table catalog table-name)))
    (if (null table-def)
        (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
        (if (not (= (length columns) 1))
            ;; Multi-column index is accepted for wiki-compat SQL surface.
            ;; Physical B+Tree build in P3-002 is single-column only.
            (dbms-make-result-ok 'ok)
            (let* ((column-name (first columns))
                   (column-def (dbms-find-column-def (dbms-table-def-columns table-def) column-name))
                   (indexes (dbms-table-indexes table-def))
                   (exists (dbms-table-find-index-by-name indexes index-name)))
              (if (null column-def)
                  (dbms-make-result-error 'dbms/column-not-found "column not found" column-name)
                  (if (not (null exists))
                      (if if-not-exists
                          (dbms-make-result-ok 'ok)
                          (dbms-make-result-error 'dbms/invalid-representation "index already exists" index-name))
                      (let* ((new-entry (list (list "name" index-name)
                                              (list "column" column-name)
                                              (list "kind" "btree")))
                             (new-table-def (dbms-table-def-with-indexes table-def (append indexes (list new-entry))))
                             (new-catalog (dbms-catalog-replace-table-def catalog new-table-def)))
                        (if (dbms-error-p new-catalog)
                            (dbms-make-result 'error new-catalog)
                            (if (dbms-tx-active-p)
                                (let ((saved (dbms-engine-save-catalog new-catalog)))
                                  (if (dbms-error-p saved)
                                      (dbms-make-result 'error saved)
                                      (dbms-make-result-ok 'ok)))
                                (let* ((state (dbms-engine-load-table-rows table-name))
                                       (rows (if (dbms-error-p state) '() (third state)))
                                       (saved-index (if (dbms-error-p state)
                                                        state
                                                        (dbms-engine-build-and-save-index table-name index-name column-name rows))))
                                  (if (dbms-error-p saved-index)
                                      (dbms-make-result 'error saved-index)
                                      (let ((saved-catalog (dbms-engine-save-catalog new-catalog)))
                                        (if (dbms-error-p saved-catalog)
                                            (dbms-make-result 'error saved-catalog)
                                            (dbms-make-result-ok 'ok)))))))))))))))

(defun dbms-engine-alter-table (catalog stmt)
  (let* ((payload (third stmt))
         (table-name (dbms-assoc-get payload "table"))
         (action (dbms-assoc-get payload "action")))
    (if (string= action "DROP-CONSTRAINT")
        (let* ((name (dbms-assoc-get payload "constraint-name"))
               (if-exists (dbms-assoc-get payload "if-exists"))
               (updated (dbms-catalog-drop-constraint catalog table-name name if-exists)))
          (if (dbms-error-p updated)
              (dbms-make-result 'error updated)
              (let ((saved (dbms-engine-save-catalog updated)))
                (if (dbms-error-p saved)
                    (dbms-make-result 'error saved)
                    (dbms-make-result-ok 'ok)))))
        (if (string= action "ADD-CONSTRAINT")
            (let* ((constraint (dbms-assoc-get payload "constraint"))
                   (updated (dbms-catalog-add-constraint catalog table-name constraint)))
              (if (dbms-error-p updated)
                  (dbms-make-result 'error updated)
                  (let ((saved (dbms-engine-save-catalog updated)))
                    (if (dbms-error-p saved)
                        (dbms-make-result 'error saved)
                        (dbms-make-result-ok 'ok)))))
            (if (string= action "ADD-COLUMN")
                (let* ((table-def (dbms-catalog-find-table catalog table-name))
                       (column-def (dbms-assoc-get payload "column-def")))
                  (if (null table-def)
                      (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
                      (if (not (dbms-column-def-p column-def))
                          (dbms-make-result-error 'dbms/invalid-representation "ADD COLUMN requires valid column definition" column-def)
                          (if (not (null (dbms-find-column-def (dbms-table-def-columns table-def)
                                                                (dbms-column-def-name column-def))))
                              (dbms-make-result-error 'dbms/duplicate-column "column already exists" (dbms-column-def-name column-def))
                              ;; Metadata-only online ADD COLUMN: disallow attrs that require eager full-table backfill.
                              (if (or (dbms-column-has-attr-p column-def 'PRIMARY-KEY)
                                      (dbms-column-has-attr-p column-def 'UNIQUE)
                                      (dbms-column-has-attr-p column-def 'NOT-NULL))
                                  (dbms-make-result-error 'dbms/not-implemented "online ADD COLUMN supports nullable/non-key columns only" column-def)
                                  (let* ((new-columns (append (dbms-table-def-columns table-def) (list column-def)))
                                         (new-table (dbms-make-table-def (dbms-table-def-name table-def)
                                                                         new-columns
                                                                         (dbms-table-def-constraints table-def)
                                                                         (dbms-table-def-options table-def)))
                                         (checked (dbms-catalog-validate-table-def catalog new-table)))
                                    (if (dbms-error-p checked)
                                        (dbms-make-result 'error checked)
                                        (let ((updated (dbms-catalog-replace-table-def catalog checked)))
                                          (if (dbms-error-p updated)
                                              (dbms-make-result 'error updated)
                                              (let ((saved (dbms-engine-save-catalog updated)))
                                                (if (dbms-error-p saved)
                                                    (dbms-make-result 'error saved)
                                                    (dbms-make-result-ok 'ok))))))))))))
                (dbms-make-result-error 'dbms/not-implemented "unsupported ALTER action" action))))))

(defun dbms-engine-insert (catalog stmt)
  (let* ((payload (third stmt))
         (table-name (dbms-assoc-get payload "table"))
         (input-cols (dbms-assoc-get payload "columns"))
         (exprs (dbms-assoc-get payload "values"))
         (table-def (dbms-catalog-find-table catalog table-name)))
    (if (null table-def)
        (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
        (let* ((state (dbms-engine-load-table-rows table-name))
               (rows (third state))
               (columns (dbms-table-def-columns table-def))
               (pairs (dbms-build-row-values-for-columns rows columns input-cols exprs columns)))
          (if (dbms-error-p pairs)
              (dbms-make-result 'error pairs)
              (let* ((new-row (dbms-make-row (dbms-next-row-id rows) pairs))
                     (new-rows (append rows (list new-row)))
                     (valid (dbms-validate-rows new-rows table-def catalog)))
                (if (dbms-error-p valid)
                    (dbms-make-result 'error valid)
                    (let ((saved (dbms-engine-save-table-rows table-name new-rows)))
                      (if (dbms-error-p saved)
                          (dbms-make-result 'error saved)
                          (if (dbms-tx-active-p)
                              (dbms-make-result-count 1)
                              (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def table-name table-def new-rows)))
                                (if (dbms-error-p rebuild)
                                    (dbms-make-result 'error rebuild)
                                    (dbms-make-result-count 1)))))))))))))

(defun dbms-engine-select (catalog stmt)
  (let* ((payload (third stmt))
         (table-name (dbms-assoc-get payload "table"))
         (select-cols (dbms-assoc-get payload "columns"))
         (where-pred (dbms-assoc-get payload "where"))
         (order-by (dbms-assoc-get payload "order-by"))
         (limit-n (dbms-assoc-get payload "limit"))
         (table-def (dbms-catalog-find-table catalog table-name)))
    (if (null table-def)
        (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
        (let* ((state (dbms-engine-load-table-rows table-name))
               (all-rows (third state))
               (table-cols (dbms-table-def-columns table-def))
               (eq-probe (dbms-predicate-simple-indexable-eq where-pred))
               (range-probe (dbms-predicate-simple-indexable-range where-pred))
               (order-col (if (null order-by) "" (first order-by)))
               (order-dir (if (null order-by) 'ASC (second order-by)))
               (scan-col (if (and (not (null range-probe)) (stringp (first range-probe)))
                             (first range-probe)
                             (if (and (not (null eq-probe)) (stringp (first eq-probe)))
                                 (first eq-probe)
                                 (if (null order-by) "" order-col))))
               (idx-entry (if (or (dbms-tx-active-p) (string= scan-col ""))
                              '()
                              (dbms-table-find-index-by-column (dbms-table-indexes table-def) scan-col)))
               (idx-data (if (null idx-entry)
                             '()
                             (dbms-storage-load-index table-name (dbms-index-entry-name idx-entry))))
               (probe-type-ok (if (not (null eq-probe))
                                  (dbms-probe-type-compatible-p table-cols (first eq-probe) (third eq-probe))
                                  (if (not (null range-probe))
                                      (dbms-probe-type-compatible-p table-cols (first range-probe) (fourth range-probe))
                                      t)))
               (index-eligible (and (not (dbms-tx-active-p))
                                    (not (null idx-entry))
                                    (dbms-btree-index-p idx-data)
                                    probe-type-ok
                                    (or (null where-pred)
                                        (and (not (null eq-probe))
                                             (string= scan-col (first eq-probe)))
                                        (and (not (null range-probe))
                                             (string= scan-col (first range-probe))))))
               (plan-details (dbms-optimizer-plan-details table-def
                                                          (length all-rows)
                                                          index-eligible
                                                          eq-probe
                                                          range-probe
                                                          order-col
                                                          scan-col
                                                          order-dir
                                                          limit-n))
               (plan-choice (dbms-assoc-get plan-details "scan-choice"))
               (use-index (and index-eligible (string= plan-choice "INDEX")))
               (idx-rids (if use-index
                             (dbms-index-rids-for-where idx-data
                                                        where-pred
                                                        (if (and (numberp limit-n)
                                                                 (or (null order-by)
                                                                     (and (string= scan-col order-col)
                                                                          (eq order-dir 'ASC))))
                                                            limit-n
                                                            '()))
                             '()))
               (filtered
                (if (and use-index (not (dbms-error-p idx-rids)))
                    (let ((ordered-rows (dbms-rows-by-row-ids-in-order all-rows idx-rids)))
                      (if (and (not (null where-pred)) (null eq-probe) (null range-probe))
                          (dbms-rows-filter-by-predicate ordered-rows where-pred table-cols)
                          ordered-rows))
                    (dbms-rows-filter-by-predicate all-rows where-pred table-cols))))
          (if (dbms-error-p filtered)
              (dbms-make-result 'error filtered)
              (let* ((out-cols (if (eq select-cols '*)
                                   (mapcar (lambda (c) (dbms-column-def-name c)) table-cols)
                                   select-cols))
                     (col-check-rest out-cols)
                     (bad-col '()))
                (while (and (null bad-col) (not (null col-check-rest)))
                  (if (null (dbms-find-column-def table-cols (car col-check-rest)))
                      (setq bad-col (car col-check-rest))
                      nil)
                  (setq col-check-rest (cdr col-check-rest)))
                (if (not (null bad-col))
                    (dbms-make-result-error 'dbms/column-not-found "column not found" bad-col)
                    (let* ((ordered
                            (if (null order-by)
                                filtered
                                (if (null (dbms-find-column-def table-cols order-col))
                                    'ORDER-BY-COLUMN-MISSING
                                    (if (and use-index
                                             (string= scan-col order-col))
                                        (if (eq order-dir 'DESC)
                                            (dbms-reverse filtered)
                                            filtered)
                                        (dbms-stable-order-rows filtered order-col order-dir)))))
                           (limited (if (eq ordered 'ORDER-BY-COLUMN-MISSING)
                                        ordered
                                        (dbms-limit-rows ordered limit-n)))
                           (projected '()))
                      (if (eq limited 'ORDER-BY-COLUMN-MISSING)
                          (dbms-make-result-error 'dbms/column-not-found "ORDER BY column not found" order-by)
                          (progn
                            (dolist (r limited)
                              (setq projected (append projected (list (dbms-row-project r out-cols)))))
                            (dbms-make-result-rows out-cols projected)))))))))))

(defun dbms-engine-update (catalog stmt)
  (let* ((payload (third stmt))
         (table-name (dbms-assoc-get payload "table"))
         (set-pairs (dbms-assoc-get payload "set"))
         (where-pred (dbms-assoc-get payload "where"))
         (table-def (dbms-catalog-find-table catalog table-name)))
    (if (null table-def)
        (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
         (let* ((state (dbms-engine-load-table-rows table-name))
               (rows (third state))
               (table-cols (dbms-table-def-columns table-def))
               (auto-touch-updated-at (dbms-should-auto-touch-updated-at-p table-name table-cols set-pairs))
               (updated '())
               (affected 0)
               (failed '()))
          ;; set 対象列存在チェック
          (let ((sr set-pairs))
            (while (and (null failed) (not (null sr)))
              (if (null (dbms-find-column-def table-cols (first (car sr))))
                  (setq failed (dbms-make-error 'dbms/column-not-found "column not found" (first (car sr))))
                  nil)
              (setq sr (cdr sr))))
          (let ((rest rows))
            (while (and (null failed) (not (null rest)))
              (let* ((row (car rest))
                     (ok (dbms-eval-predicate where-pred row table-cols)))
                (if (dbms-error-p ok)
                    (setq failed ok)
                    (if ok
                        (let ((newvals (dbms-row-values row))
                              (sr set-pairs))
                          (while (and (null failed) (not (null sr)))
                            (let* ((col-name (first (car sr)))
                                   (expr (second (car sr)))
                                   (col-def (dbms-find-column-def table-cols col-name))
                                   (ev (dbms-eval-expr expr row table-cols)))
                              (if (dbms-error-p ev)
                                  (setq failed ev)
                                  (let ((et (first ev))
                                        (evv (second ev))
                                        (target-type (dbms-column-def-type col-def)))
                                    (if (dbms-type-compatible-p target-type et)
                                        (setq newvals (dbms-row-values-set newvals col-name evv))
                                        (setq failed (dbms-make-error 'dbms/type-mismatch "update value type mismatch" (list col-name target-type et)))))))
                            (setq sr (cdr sr)))
                          (if (null failed)
                              (if auto-touch-updated-at
                                  (setq newvals (dbms-row-values-set newvals "updated_at" (dbms-current-timestamptz)))
                                  nil)
                              nil)
                          (if (null failed)
                              (progn
                                (setq updated (append updated (list (dbms-make-row (dbms-row-id row) newvals))))
                                (setq affected (+ affected 1)))
                              nil))
                        (setq updated (append updated (list row)))))
                )
              (setq rest (cdr rest))))
          (if (dbms-error-p failed)
              (dbms-make-result 'error failed)
              (let ((valid (dbms-validate-rows updated table-def catalog)))
                (if (dbms-error-p valid)
                    (dbms-make-result 'error valid)
                    (let ((saved (dbms-engine-save-table-rows table-name updated)))
                      (if (dbms-error-p saved)
                          (dbms-make-result 'error saved)
                          (if (dbms-tx-active-p)
                              (dbms-make-result-count affected)
                              (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def table-name table-def updated)))
                                (if (dbms-error-p rebuild)
                                    (dbms-make-result 'error rebuild)
                                    (dbms-make-result-count affected)))))))))))))

(defun dbms-collect-referencing-fks (catalog target-table)
  (let ((pairs (dbms-catalog-tables catalog))
        (out '()))
    (dolist (p pairs)
      (let* ((child-name (first p))
             (child-def (second p))
             (cons-list (dbms-table-def-constraints child-def)))
        (dolist (c cons-list)
          (if (and (eq (dbms-constraint-kind c) 'foreign-key)
                   (string= (second (dbms-constraint-spec c)) target-table))
              (setq out (append out (list (list child-name child-def c))))
              nil))))
    out))

(defun dbms-apply-on-delete-to-child-row (child-row deleted-rows fk-spec)
  (let* ((local-cols (first fk-spec))
         (ref-cols (third fk-spec))
         (on-delete (fourth fk-spec))
         (local-vals (dbms-row-values-by-cols child-row local-cols))
         (hit nil))
    (dolist (dr deleted-rows)
      (if (dbms-values-equal-list-p local-vals (dbms-row-values-by-cols dr ref-cols))
          (setq hit t)
          nil))
    (if (not hit)
        (list "KEEP" child-row)
        (if (eq on-delete 'CASCADE)
            (list "DROP" '())
            ;; SET NULL
            (let ((vals (dbms-row-values child-row)))
              (dolist (lc local-cols)
                (setq vals (dbms-row-values-set vals lc 'NULL)))
              (list "KEEP" (dbms-make-row (dbms-row-id child-row) vals)))))))

(defun dbms-propagate-on-delete (catalog target-table deleted-rows)
  (let ((refs (dbms-collect-referencing-fks catalog target-table))
        (failed '()))
    (dolist (entry refs)
      (if (dbms-error-p failed)
          nil
          (let* ((child-name (first entry))
                 (child-def (second entry))
                 (fk (third entry))
                 (fk-spec (dbms-constraint-spec fk))
                 (state (dbms-engine-load-table-rows child-name)))
            (if (dbms-error-p state)
                (setq failed state)
                (let* ((rows (third state))
                       (new-rows '()))
                  (dolist (r rows)
                    (let ((res (dbms-apply-on-delete-to-child-row r deleted-rows fk-spec)))
                      (if (string= (first res) "KEEP")
                          (setq new-rows (append new-rows (list (second res))))
                          nil)))
                  (let ((valid (dbms-validate-rows new-rows child-def catalog)))
                    (if (dbms-error-p valid)
                        (setq failed valid)
                        (let ((saved (dbms-engine-save-table-rows child-name new-rows)))
                          (if (dbms-error-p saved)
                              (setq failed saved)
                              nil)))))))))
    (if (dbms-error-p failed) failed t)))

(defun dbms-engine-delete (catalog stmt)
  (let* ((payload (third stmt))
         (table-name (dbms-assoc-get payload "table"))
         (where-pred (dbms-assoc-get payload "where"))
         (table-def (dbms-catalog-find-table catalog table-name)))
    (if (null table-def)
        (dbms-make-result-error 'dbms/table-not-found "table not found" table-name)
        (let* ((state (dbms-engine-load-table-rows table-name))
               (rows (third state))
               (table-cols (dbms-table-def-columns table-def))
               (deleted '())
               (kept '())
               (affected 0)
               (failed '()))
          (dolist (row rows)
            (if (dbms-error-p failed)
                nil
                (let ((ok (dbms-eval-predicate where-pred row table-cols)))
                  (if (dbms-error-p ok)
                      (setq failed ok)
                      (if ok
                          (progn
                            (setq affected (+ affected 1))
                            (setq deleted (append deleted (list row))))
                          (setq kept (append kept (list row))))))))
          (if (dbms-error-p failed)
              (dbms-make-result 'error failed)
              (let ((saved (dbms-engine-save-table-rows table-name kept)))
                (if (dbms-error-p saved)
                    (dbms-make-result 'error saved)
                    (let ((prop (dbms-propagate-on-delete catalog table-name deleted)))
                      (if (dbms-error-p prop)
                          (dbms-make-result 'error prop)
                          (if (dbms-tx-active-p)
                              (dbms-make-result-count affected)
                              (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def table-name table-def kept)))
                                (if (dbms-error-p rebuild)
                                    (dbms-make-result 'error rebuild)
                                    (dbms-make-result-count affected)))))))))))))

(defun dbms-engine-begin (_catalog _stmt)
  (if (dbms-tx-active-p)
      (dbms-make-result-error 'dbms/tx-already-active "transaction is already active" 'BEGIN)
      (let ((tx-id *dbms-next-tx-id*)
            (catalog (dbms-catalog-load))
            (states '()))
        (setq states (dbms-load-table-states (dbms-catalog-table-names catalog)))
        (setq *dbms-tx-snapshot-catalog* catalog)
        (if (dbms-error-p states)
            (setq *dbms-tx-snapshot-states* '())
            (setq *dbms-tx-snapshot-states* states))
        (setq *dbms-tx-staged-catalog* catalog)
        (setq *dbms-tx-staged-table-states* (if (dbms-error-p states) '() states))
        (setq *dbms-next-tx-id* (+ *dbms-next-tx-id* 1))
        (setq *dbms-tx-isolation-level* *dbms-session-isolation-level*)
        (setq *dbms-tx-state* (dbms-make-tx-state 'active '() '() tx-id))
        (dbms-make-result-ok 'ok))))

(defun dbms-engine-commit (_catalog _stmt)
  (if (eq (dbms-tx-state-status *dbms-tx-state*) 'active)
      (let ((tx-id (dbms-tx-state-tx-id *dbms-tx-state*))
            (writes (dbms-tx-state-write-set *dbms-tx-state*))
            (failed '())
            (result '()))
        ;; WAL append/flush must complete before any data file writes.
        (let ((wal-begin (dbms-storage-wal-append-record tx-id 'begin 'tx-begin '())))
          (if (dbms-error-p wal-begin)
              (setq failed wal-begin)
              nil))
        (if (and (null failed) (dbms-catalog-p *dbms-tx-staged-catalog*))
            (let ((wal-catalog (dbms-storage-wal-append-record tx-id
                                                               'data
                                                               'catalog-replace
                                                               (list *dbms-tx-staged-catalog*))))
              (if (dbms-error-p wal-catalog)
                  (setq failed wal-catalog)
                  nil))
            nil)
        (dolist (name writes)
          (if (dbms-error-p failed)
              nil
              (let ((entry (dbms-find-staged-table-state-pair name *dbms-tx-staged-table-states*)))
                (if (null entry)
                    nil
                    (let* ((state (second entry))
                           (wal-table (dbms-storage-wal-append-record tx-id
                                                                      'data
                                                                      'table-replace
                                                                      (list name state))))
                      (if (dbms-error-p wal-table)
                          (setq failed wal-table)
                          nil))))))
        (if (null failed)
            (let ((wal-commit (dbms-storage-wal-append-record tx-id 'commit 'tx-commit '())))
              (if (dbms-error-p wal-commit)
                  (setq failed wal-commit)
                  nil))
            nil)
        (if (null failed)
            (dbms-test-commit-failpoint tx-id)
            nil)

        ;; Data-file commit phase (after WAL commit marker has been persisted).
        (if (and (null failed) (dbms-catalog-p *dbms-tx-staged-catalog*))
            (let ((saved-catalog (dbms-catalog-save *dbms-tx-staged-catalog*)))
              (if (dbms-error-p saved-catalog)
                  (setq failed saved-catalog)
                  nil))
            nil)
        (dolist (name writes)
          (if (dbms-error-p failed)
              nil
              (let ((entry (dbms-find-staged-table-state-pair name *dbms-tx-staged-table-states*)))
                (if (null entry)
                    nil
                    (let* ((state (second entry))
                           (saved (dbms-storage-save-table-rows name (third state))))
                      (if (dbms-error-p saved)
                          (setq failed saved)
                          nil))))))
        ;; Rebuild index files for tables touched in this transaction.
        (dolist (name writes)
          (if (dbms-error-p failed)
              nil
              (let ((table-def (dbms-catalog-find-table *dbms-tx-staged-catalog* name)))
                (if (null table-def)
                    nil
                    (let* ((entry (dbms-find-staged-table-state-pair name *dbms-tx-staged-table-states*))
                           (state (if (null entry)
                                      (dbms-storage-load-table-rows name)
                                      (second entry))))
                      (if (dbms-error-p state)
                          (setq failed state)
                          (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def name table-def (third state))))
                            (if (dbms-error-p rebuild)
                                (setq failed rebuild)
                                nil))))))))
        (setq result
              (if (dbms-error-p failed)
            (progn
              (setq *dbms-tx-state* (dbms-make-tx-state 'aborted
                                                        (dbms-tx-state-read-set *dbms-tx-state*)
                                                        (dbms-tx-state-write-set *dbms-tx-state*)
                                                        tx-id))
              (dbms-lock-release-tx tx-id)
              (dbms-make-result 'error failed))
            (progn
              (setq *dbms-tx-state* (dbms-make-tx-state 'committed
                                                        (dbms-tx-state-read-set *dbms-tx-state*)
                                                        (dbms-tx-state-write-set *dbms-tx-state*)
                                                        tx-id))
              (dbms-lock-release-tx tx-id)
              (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
              (setq *dbms-tx-state* (dbms-tx-state-idle))
              (dbms-make-result-ok 'ok))))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        result)
      (progn
        (setq *dbms-tx-state* (dbms-tx-state-idle))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        (dbms-make-result-error 'dbms/tx-not-active "no active transaction" 'COMMIT))))

(defun dbms-engine-rollback (_catalog _stmt)
  (if (eq (dbms-tx-state-status *dbms-tx-state*) 'active)
      (let ((tx-id (dbms-tx-state-tx-id *dbms-tx-state*))
            (failed '()))
        ;; Restore catalog first, then table states captured at BEGIN.
        (if (dbms-catalog-p *dbms-tx-snapshot-catalog*)
            (let ((saved-catalog (dbms-catalog-save *dbms-tx-snapshot-catalog*)))
              (if (dbms-error-p saved-catalog)
                  (setq failed saved-catalog)
                  nil))
            nil)
        (if (dbms-error-p failed)
            nil
            (dolist (entry *dbms-tx-snapshot-states*)
              (if (dbms-error-p failed)
                  nil
                  (let ((name (first entry))
                        (state (second entry)))
                    (if (or (not (stringp name)) (not (dbms-table-state-p state)))
                        (setq failed (dbms-make-error 'dbms/invalid-representation "invalid tx snapshot state" entry))
                        (let ((saved (dbms-storage-save-table-rows name (third state))))
                          (if (dbms-error-p saved)
                              (setq failed saved)
                              nil)))))))
        (setq *dbms-tx-state* (dbms-make-tx-state 'aborted
                                                  (dbms-tx-state-read-set *dbms-tx-state*)
                                                  (dbms-tx-state-write-set *dbms-tx-state*)
                                                  tx-id))
        (dbms-lock-release-tx tx-id)
        (setq *dbms-tx-isolation-level* 'READ-COMMITTED)
        (setq *dbms-tx-state* (dbms-tx-state-idle))
        (setq *dbms-tx-snapshot-catalog* '())
        (setq *dbms-tx-snapshot-states* '())
        (setq *dbms-tx-staged-catalog* '())
        (setq *dbms-tx-staged-table-states* '())
        (if (dbms-error-p failed)
            (dbms-make-result 'error failed)
            (dbms-make-result-ok 'ok)))
      (dbms-make-result-error 'dbms/tx-not-active "no active transaction" 'ROLLBACK)))

(defun dbms-catalog-table-names (catalog)
  (let ((pairs (dbms-catalog-tables catalog))
        (out '()))
    (dolist (p pairs)
      (setq out (append out (list (first p)))))
    out))

(defun dbms-load-table-states (table-names)
  (let ((rest table-names)
        (out '())
        (failed '()))
    (while (and (null failed) (not (null rest)))
      (let* ((name (car rest))
             (state (dbms-storage-load-table-rows name)))
        (if (dbms-error-p state)
            (setq failed state)
            (setq out (append out (list (list name state))))))
      (setq rest (cdr rest)))
    (if (dbms-error-p failed)
        failed
        out)))

(defun dbms-dump-payload-p (v)
  (and (listp v)
       (>= (length v) 4)
       (eq (first v) 'dbms-dump)
       (numberp (second v))
       (dbms-catalog-p (third v))
       (listp (fourth v))))

(defun dbms-admin-dump (dump-path)
  (if (or (null dump-path) (not (stringp dump-path)) (string= dump-path ""))
      (dbms-make-result-error 'dbms/invalid-representation "dump-path must be non-empty string" dump-path)
      (let* ((catalog (dbms-catalog-load))
             (table-names (dbms-catalog-table-names catalog))
             (states (dbms-load-table-states table-names)))
        (if (dbms-error-p states)
            (dbms-make-result 'error states)
            (let* ((payload (list 'dbms-dump 1 catalog states))
                   (saved (dbms-storage-atomic-replace dump-path payload)))
              (if (dbms-error-p saved)
                  (dbms-make-result 'error saved)
                  (dbms-make-result-ok dump-path)))))))

(defun dbms-admin-restore (dump-path)
  (if (or (null dump-path) (not (stringp dump-path)) (string= dump-path ""))
      (dbms-make-result-error 'dbms/invalid-representation "dump-path must be non-empty string" dump-path)
      (let ((raw (dbms-storage-read-sexpr-file dump-path)))
        (if (not (dbms-dump-payload-p raw))
            (dbms-make-result-error 'dbms/invalid-representation "invalid dump payload" dump-path)
            (let* ((catalog (third raw))
                   (states (fourth raw))
                   (saved-catalog (dbms-catalog-save catalog))
                   (failed '()))
              (if (dbms-error-p saved-catalog)
                  (dbms-make-result 'error saved-catalog)
                  (progn
                    (dolist (entry states)
                      (if (dbms-error-p failed)
                          nil
                          (let ((name (first entry))
                                (state (second entry)))
                            (if (or (not (stringp name))
                                    (not (dbms-table-state-p state)))
                                (setq failed (dbms-make-error 'dbms/invalid-representation "invalid table-state entry in dump" entry))
                                (let ((saved (dbms-storage-save-table-rows name (third state))))
                                  (if (dbms-error-p saved)
                                      (setq failed saved)
                                      (let ((table-def (dbms-catalog-find-table catalog name)))
                                        (if (null table-def)
                                            nil
                                            (let ((rebuild (dbms-engine-rebuild-table-indexes-from-def name table-def (third state))))
                                              (if (dbms-error-p rebuild)
                                                  (setq failed rebuild)
                                                  nil))))))))))
                    (if (dbms-error-p failed)
                        (dbms-make-result 'error failed)
                        (dbms-make-result-ok dump-path)))))))))

;; Wiki admin compatibility wrappers:
;; ("ok" <path>) | ("error" <message>)
(defun dbms-wiki-backup (dump-path)
  (let ((r (dbms-admin-dump dump-path)))
    (if (and (dbms-result-p r) (eq (second r) 'ok))
        (list "ok" (third r))
        (if (and (dbms-result-p r) (eq (second r) 'error) (dbms-error-p (third r)))
            (list "error" (third (third r)))
            (list "error" "backup failed")))))

(defun dbms-wiki-restore (dump-path)
  (let ((r (dbms-admin-restore dump-path)))
    (if (and (dbms-result-p r) (eq (second r) 'ok))
        (list "ok" (third r))
        (if (and (dbms-result-p r) (eq (second r) 'error) (dbms-error-p (third r)))
            (list "error" (third (third r)))
            (list "error" "restore failed")))))

(defun dbms-engine-dispatch (catalog stmt)
  (let ((kind (second stmt))
        (mode '())
        (target "")
        (lock-res '())
        (result '()))
    (if (dbms-tx-active-p)
        (progn
          (setq mode (dbms-stmt-lock-mode kind))
          (setq target (dbms-stmt-lock-target stmt))
          (if (and (not (null mode))
                   (not (string= target "")))
              (progn
                (setq lock-res (dbms-lock-acquire (dbms-tx-state-tx-id *dbms-tx-state*) target mode))
                (if (dbms-error-p lock-res)
                    (progn
                      (if (or (eq (dbms-error-code lock-res) 'dbms/deadlock-detected)
                              (eq *dbms-tx-isolation-level* 'SERIALIZABLE))
                          (dbms-abort-active-tx-on-conflict!)
                          nil)
                      (setq result (dbms-make-result 'error lock-res)))
                    nil))
              nil))
        nil)
    (if (and (dbms-result-p result) (eq (second result) 'error))
        result
        (progn
    (setq result
    (cond
     ((eq kind 'begin) (dbms-engine-begin catalog stmt))
     ((eq kind 'commit) (dbms-engine-commit catalog stmt))
     ((eq kind 'rollback) (dbms-engine-rollback catalog stmt))
     ((eq kind 'create-table) (dbms-engine-create-table catalog stmt))
     ((eq kind 'create-table-wiki) (dbms-engine-create-table-wiki catalog stmt))
     ((eq kind 'create-index) (dbms-engine-create-index catalog stmt))
     ((eq kind 'analyze) (dbms-engine-analyze catalog stmt))
     ((eq kind 'vacuum) (dbms-engine-vacuum catalog stmt))
     ((eq kind 'explain) (dbms-engine-explain catalog stmt))
     ((eq kind 'alter-table) (dbms-engine-alter-table catalog stmt))
     ((eq kind 'insert) (dbms-engine-insert catalog stmt))
     ((eq kind 'select) (dbms-engine-select catalog stmt))
     ((eq kind 'update) (dbms-engine-update catalog stmt))
     ((eq kind 'delete) (dbms-engine-delete catalog stmt))
     (t (dbms-make-result-error 'dbms/not-implemented "statement not implemented" kind))))
    (if (and (dbms-result-p result)
             (not (eq (second result) 'error)))
        (dbms-tx-record-statement! stmt)
        nil)
    ;; READ COMMITTED: release shared read locks at statement boundary.
    (if (and (dbms-tx-active-p)
             (or (eq kind 'select)
                 (eq kind 'explain))
             (eq *dbms-tx-isolation-level* 'READ-COMMITTED)
             (not (string= target "")))
        (dbms-lock-release-shared-on-table (dbms-tx-state-tx-id *dbms-tx-state*) target)
        nil)
    result))))

(defun dbms-exec-sql (catalog sql-text)
  (let ((ast (dbms-parse-sql sql-text))
        (effective-catalog (dbms-engine-current-catalog)))
    (if (dbms-error-p ast)
        (dbms-make-result 'error ast)
        (let ((stmts (dbms-ast-statements ast)))
          (if (or (null stmts) (not (= (length stmts) 1)))
              (dbms-make-result-error 'dbms/parse-error "single statement required" sql-text)
              (dbms-engine-dispatch effective-catalog (first stmts)))))))
